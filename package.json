{
  "name": "lumi-monorepo",
  "version": "0.0.0",
  "private": true,
  "packageManager": "pnpm@10.32.1",
  "scripts": {
    "admin:dev": "pnpm --filter lumi-admin-scaffold dev",
    "admin:build": "pnpm --filter lumi-admin-scaffold build",
    "admin:lint": "pnpm --filter lumi-admin-scaffold lint",
    "typecheck": "pnpm --filter lumi-admin-scaffold exec tsc --noEmit && pnpm --filter lumi-school-admin exec tsc --noEmit",
    "demo:reseed:dry-run": "tsx scripts/reseed_demo_school.ts --dry-run",
    "demo:preflight": "tsx admin/scripts/demo-preflight.ts",
    "test:demo-preflight": "tsx --test admin/test/demo-preflight-core.test.ts",
    "test:demo-controls": "tsx --test admin/test/demo-control-model.test.ts admin/test/demo-reprovision-contract.test.ts",
    "test:demo-plan": "tsx --test packages/server-ops/test/demoSchool.plan.test.ts",
    "test:audio-authority": "tsx --test packages/server-ops/test/comprehensionRetention.parity.test.ts packages/server-ops/test/retentionRunStats.test.ts",
    "test:flag-parity": "tsx --test packages/server-ops/test/aiEvalAuthority.parity.test.ts packages/server-ops/test/authority.parity.test.ts test/cover_ocr_flag.parity.test.ts",
    "test:book-deletion-cascade": "tsx --test packages/server-ops/test/communityBookDeletionCascade.test.ts packages/server-ops/test/allocationCascade.parity.test.ts packages/server-ops/test/concurrency.test.ts",
    "test:domain-associations": "node --test test/domain_associations.test.mjs",
    "test:audio-retention:integration": "scripts/with-jdk21.sh functions/node_modules/.bin/firebase emulators:exec --config firebase.deletion.json --only firestore --project demo-lumi-server-ops-audio \"pnpm exec tsx --test packages/server-ops/test/comprehensionRetention.integration.test.ts\"",
    "test:book-deletion:integration": "scripts/with-jdk21.sh functions/node_modules/.bin/firebase emulators:exec --config firebase.deletion.json --only firestore --project demo-lumi-community-book-deletion \"pnpm exec tsx --test packages/server-ops/test/communityBookDeletion.integration.test.ts\"",
    "test:demo-readiness": "bash scripts/demo-readiness-local.sh"
  },
  "devDependencies": {
    "firebase-admin": "^13.10.0",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3"
  },
  "pnpm": {
    "overrides": {
      "@grpc/grpc-js": "1.14.4",
      "form-data@<2.5.6": "2.5.6",
      "hono": "4.12.30",
      "protobufjs": "7.6.3",
      "websocket-driver": "0.7.5"
    }
  }
}
