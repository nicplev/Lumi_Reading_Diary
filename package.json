{
  "name": "lumi-monorepo",
  "version": "0.0.0",
  "private": true,
  "packageManager": "pnpm@10.32.1",
  "scripts": {
    "admin:dev": "pnpm --filter lumi-admin-scaffold dev",
    "admin:build": "pnpm --filter lumi-admin-scaffold build",
    "admin:lint": "pnpm --filter lumi-admin-scaffold lint",
    "typecheck": "pnpm -r --if-present exec tsc --noEmit",
    "demo:reseed:dry-run": "tsx scripts/reseed_demo_school.ts --dry-run",
    "demo:preflight": "tsx admin/scripts/demo-preflight.ts",
    "test:demo-plan": "tsx --test packages/server-ops/test/demoSchool.plan.test.ts",
    "test:demo-readiness": "bash scripts/demo-readiness-local.sh"
  },
  "devDependencies": {
    "firebase-admin": "^13.10.0",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3"
  },
  "pnpm": {
    "overrides": {
      "@grpc/grpc-js": "1.14.4",
      "form-data@<2.5.6": "2.5.6",
      "hono": "4.12.30",
      "protobufjs": "7.6.3",
      "websocket-driver": "0.7.5"
    }
  }
}
