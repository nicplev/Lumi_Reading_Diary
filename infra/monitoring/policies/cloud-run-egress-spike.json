{
  "displayName": "Lumi production: Cloud Run egress spike",
  "combiner": "OR",
  "enabled": true,
  "conditions": [
    {
      "displayName": "More than 50 MiB sent by Cloud Run in one hour",
      "conditionThreshold": {
        "filter": "resource.type=\"cloud_run_revision\" AND metric.type=\"run.googleapis.com/container/network/sent_bytes_count\"",
        "comparison": "COMPARISON_GT",
        "thresholdValue": 52428800,
        "duration": "0s",
        "aggregations": [
          {
            "alignmentPeriod": "3600s",
            "perSeriesAligner": "ALIGN_SUM",
            "crossSeriesReducer": "REDUCE_SUM"
          }
        ],
        "trigger": { "count": 1 }
      }
    }
  ],
  "notificationChannels": [
    "projects/lumi-ninc-au/notificationChannels/6689107490351214266",
    "projects/lumi-ninc-au/notificationChannels/11207813659675718192"
  ],
  "documentation": {
    "mimeType": "text/markdown",
    "content": "Investigate abusive endpoints, response amplification, unexpected downloads and compromised runtime behaviour. The preceding 30-day maximum was about 4.5 MB/hour."
  },
  "userLabels": { "service": "lumi", "severity": "medium", "signal": "egress" }
}
