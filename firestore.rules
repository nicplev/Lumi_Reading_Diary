rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Healthcheck doc read by every foreground client every ~600s as the L3 probe.
    // Tiny, public to signed-in users, never written from the client.
    // Seed once via an admin script: `_meta/healthcheck = { version: 1 }`.
    match /_meta/healthcheck {
      allow read: if request.auth != null;
      allow write: if false;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function getUserData(schoolId) {
      let userPath = /databases/$(database)/documents/schools/$(schoolId)/users/$(request.auth.uid);
      let parentPath = /databases/$(database)/documents/schools/$(schoolId)/parents/$(request.auth.uid);

      return exists(userPath)
          ? get(userPath).data
          : exists(parentPath)
              ? get(parentPath).data
              : null;
    }

    function userRole(schoolId) {
      let userData = getUserData(schoolId);
      return userData == null ? null : userData.role;
    }

    function isSchoolAdmin(schoolId) {
      return isSignedIn() && userRole(schoolId) == 'schoolAdmin';
    }

    function isTeacher(schoolId) {
      return isSignedIn() && userRole(schoolId) == 'teacher';
    }

    function isParentMember(schoolId) {
      return isSignedIn() && userRole(schoolId) == 'parent';
    }

    function isValidTermsAcceptanceUpdate() {
      let changed = request.resource.data.diff(resource.data).affectedKeys();
      return !changed.hasAny([
        'termsAccepted',
        'termsAcceptedAt',
        'termsAcceptedVersion',
        'termsAcceptedPlatform'
      ]) || (
        changed.hasOnly([
          'termsAccepted',
          'termsAcceptedAt',
          'termsAcceptedVersion',
          'termsAcceptedPlatform'
        ]) &&
        request.resource.data.termsAccepted == true &&
        request.resource.data.termsAcceptedAt == request.time &&
        request.resource.data.termsAcceptedVersion is string &&
        request.resource.data.termsAcceptedVersion.size() > 0 &&
        request.resource.data.termsAcceptedVersion.size() <= 32 &&
        request.resource.data.termsAcceptedPlatform is string &&
        request.resource.data.termsAcceptedPlatform.size() > 0 &&
        request.resource.data.termsAcceptedPlatform.size() <= 16
      );
    }

    function belongsToSchool(schoolId) {
      return isSignedIn() &&
          (exists(/databases/$(database)/documents/schools/$(schoolId)/users/$(request.auth.uid)) ||
              exists(/databases/$(database)/documents/schools/$(schoolId)/parents/$(request.auth.uid)));
    }

    function linkedChildrenForSchool(schoolId) {
      let userData = getUserData(schoolId);
      return userData == null || userData.linkedChildren == null
          ? []
          : userData.linkedChildren;
    }

    function classContainsLinkedChildren(schoolId, classId, linkedChildren) {
      return classId != null &&
          exists(/databases/$(database)/documents/schools/$(schoolId)/classes/$(classId)) &&
          get(/databases/$(database)/documents/schools/$(schoolId)/classes/$(classId)).data.studentIds.hasAny(linkedChildren);
    }

    // Does the signed-in teacher own/co-teach `classId`? The class document's
    // teacherId/teacherIds is the single source of truth for the teacher↔class
    // relationship (it's what every other class rule and the portal's
    // class-by-teacher query use). Checking it here — rather than a denormalised
    // `classIds` on the teacher's user doc, which the school portal never keeps
    // in sync on class create/update — is what keeps teacher-proxy logging working.
    function teacherTeachesClass(schoolId, classId) {
      let classPath = /databases/$(database)/documents/schools/$(schoolId)/classes/$(classId);
      return classId is string &&
          classId != '' &&
          exists(classPath) &&
          (
            get(classPath).data.get('teacherId', '') == request.auth.uid ||
            request.auth.uid in get(classPath).data.get('teacherIds', [])
          );
    }

    function parentCanReadAllocation(schoolId, allocationData) {
      let linkedChildren = linkedChildrenForSchool(schoolId);

      return isParentMember(schoolId) &&
          linkedChildren.size() > 0 &&
          allocationData.studentIds != null &&
          (
            allocationData.studentIds.hasAny(linkedChildren) ||
            (
              allocationData.studentIds.size() == 0 &&
              classContainsLinkedChildren(
                schoolId,
                allocationData.classId,
                linkedChildren,
              )
            )
          );
    }

    // ── Access / entitlement helper ─────────────────────────────────
    // Fail-closed verdict for a student's materialised `access` map. Live
    // only when status == 'active' AND the absolute hard-expiry is still in
    // the future. Safe `.get(key, default)` accessors make a missing `access`
    // map (legacy docs) evaluate to DENIED rather than raising: an absent
    // status defaults to '' (≠ 'active'), and an absent expiresAt defaults to
    // request.time (so `> request.time` is false). The expiresAt comparison is
    // the date-driven backstop — access lapses on schedule even if no Cloud
    // Function ever runs. school-wide suspension flows through here too: the
    // subscription trigger flips each student's access.status to 'suspended'.
    function studentAccessLive(studentData) {
      return studentData.get('isActive', true) == true &&
          studentData.get('access', {}).get('status', '') == 'active' &&
          studentData.get('access', {}).get('expiresAt', request.time) > request.time;
    }

    // ── Developer impersonation helpers ─────────────────────────────
    // An allowlisted developer can start a short-lived impersonation
    // session via a Cloud Function, which mints a custom token carrying
    // these claims. The claims widen read access to a single target
    // school and hard-block every write path (devReadOnly).
    //
    // All claim reads use `.get(key, default)` so that normal (non-dev)
    // sessions — where these claims are absent — evaluate the helpers
    // cleanly to `false` instead of raising "property undefined".
    function isDevImpersonating() {
      return request.auth != null
          && request.auth.token.get('devImpersonating', false) == true
          && request.auth.token.get('impersonationSessionId', '') is string
          && request.auth.token.get('impersonationSessionId', '').size() > 0;
    }

    // Reads the live session doc named by the token's sessionId claim and
    // confirms it is still active, targets THIS school, and hasn't expired.
    // This is what makes super-admin revocation and the 30-min TTL take effect
    // immediately: the claims alone would otherwise keep granting read access
    // for the full ~1h ID-token lifetime, outliving the session. Costs one
    // get() per impersonated read (dev-only, low volume); normal users never
    // reach it because isDevImpersonating() short-circuits to false first.
    function impersonationSessionLive(schoolId) {
      let sid = request.auth.token.get('impersonationSessionId', '');
      let session = get(/databases/$(database)/documents/devImpersonationSessions/$(sid));
      return session != null
          && session.data.status == 'active'
          && session.data.targetSchoolId == schoolId
          && request.time < session.data.expiresAt;
    }

    function isDevImpersonatingSchool(schoolId) {
      return isDevImpersonating()
          && request.auth.token.get('impersonationSchoolId', '') == schoolId
          && impersonationSessionLive(schoolId);
    }

    function devReadOnly() {
      return request.auth != null
          && request.auth.token.get('devReadOnly', false) == true;
    }

    // The shared-password sales-demo administrator is allowed to skip MFA
    // only because it is confined to a synthetic tenant and is read-only.
    // This is an Admin-SDK custom claim; clients cannot grant it themselves.
    function demoAdminReadOnly() {
      return request.auth != null
          && request.auth.token.get('demoAccount', false) == true
          && request.auth.token.get('demoAdminMfaExempt', false) == true
          && request.auth.token.get('demoReadOnly', false) == true;
    }

    function isDemoAccount() {
      return request.auth != null
          && request.auth.token.get('demoAccount', false) == true;
    }

    // Shared demo credentials are never granted the ordinary write surface.
    // Only the ordinary demo teacher/parent claim shape may continue through
    // the normal role/ownership/schema checks for school-local content. The
    // shared school administrator remains read-only everywhere because its
    // mobile role is only a pointer to the web portal.
    function demoAccountMayWriteSchoolContent(schoolId) {
      let ordinaryShape =
          request.auth.token.get('demoAdminMfaExempt', false) == false
          && request.auth.token.get('demoReadOnly', false) == false
          && request.auth.token.get('demoInteractive', false) == false;
      let school = get(
        /databases/$(database)/documents/schools/$(schoolId)
      );
      let reseed = get(
        /databases/$(database)/documents/demoAccess/reseedStatus
      );
      return isDemoAccount()
          && !devReadOnly()
          && request.auth.token.get('demoSchoolId', '') == schoolId
          && ordinaryShape
          && school.data.get('isDemo', false) == true
          && reseed.data.get('schoolId', '') == schoolId
          && reseed.data.get('state', '') == 'succeeded'
          && request.auth.token.get('demoGenerationId', '') is string
          && request.auth.token.get('demoGenerationId', '').size() > 0
          && request.auth.token.get('demoGenerationId', '') ==
              reseed.data.get('leaseId', '');
    }

    function validCurrentDemoAllocation(schoolId, data) {
      return data.demoEphemeral == true
          && data.demoGenerationId is string
          && data.demoGenerationId.size() > 0
          && data.demoGenerationId ==
              request.auth.token.get('demoGenerationId', '')
          && data.demoOrigin in [
            'flutter_camera',
            'flutter_manual'
          ]
          && data.schoolId == schoolId
          && data.classId is string
          && data.classId.size() > 0
          && data.studentIds is list
          && data.studentIds.size() <= 100
          && (data.assignmentItems == null ||
            (data.assignmentItems is list && data.assignmentItems.size() <= 50))
          && data.type in ['byLevel', 'byTitle', 'freeChoice']
          && data.cadence in ['daily', 'weekly', 'fortnightly', 'custom']
          && data.targetMinutes is int
          && data.targetMinutes >= 1
          && data.targetMinutes <= 180;
    }

    function writeAllowedForDev() {
      return !devReadOnly() && !isDemoAccount();
    }

    function writeAllowedForSchoolContent(schoolId) {
      return writeAllowedForDev()
          || demoAccountMayWriteSchoolContent(schoolId);
    }

    // ── Per-school feature gates ────────────────────────────────────
    // Server-side backstop for parent↔teacher messaging (the reading-log
    // comment threads). One get() of the school doc — cached per request and
    // only on the low-volume comment-create path — reads
    // settings.messaging.enabled. Defaults to TRUE for legacy docs without the
    // setting, so messaging fails OPEN: an enabled school is never blocked, and
    // a school that has explicitly turned messaging off can't have comment
    // threads created even by a stale or tampered client.
    function messagingEnabled(schoolId) {
      return get(/databases/$(database)/documents/schools/$(schoolId))
          .data.get('settings', {})
          .get('messaging', {})
          .get('enabled', true);
    }

    // Server-side backstop for the parent app's one-tap quick logging shortcut.
    // Defaults to TRUE for legacy schools. When a school admin disables it, a
    // stale/tampered parent client cannot create new logs marked
    // `metadata.quickLog == true`; detailed logs remain allowed.
    function quickLoggingEnabled(schoolId) {
      return get(/databases/$(database)/documents/schools/$(schoolId))
          .data.get('settings', {})
          .get('quickLogging', {})
          .get('enabled', true);
    }

    match /schools/{schoolId} {
      // AI evaluation commercial/runtime settings are server-owned. The
      // mobile app can read only the platformConfig/aiEvaluation kill switch;
      // it must never grant a school an entitlement or change provider limits.
      function aiEvaluationSettingsAbsentOnCreate() {
        let settings = request.resource.data.get('settings', {});
        return settings is map && !settings.keys().hasAny(['aiEvaluation']);
      }

      function aiEvaluationSettingsUnchanged() {
        let oldSettings = resource.data.get('settings', {});
        let newSettings = request.resource.data.get('settings', {});
        return oldSettings is map &&
            newSettings is map &&
            oldSettings.get('aiEvaluation', null) ==
                newSettings.get('aiEvaluation', null);
      }

      // The school admin portal records a versioned authority statement and
      // retention choice with Admin SDK. Mobile/Web Firestore clients must not
      // be able to forge that evidence or enable child voice collection by
      // editing the nested school setting directly.
      function comprehensionRecordingSettingsAbsentOnCreate() {
        let settings = request.resource.data.get('settings', {});
        return settings is map &&
            !settings.keys().hasAny(['comprehensionRecording']);
      }

      function comprehensionRecordingSettingsUnchanged() {
        let oldSettings = resource.data.get('settings', {});
        let newSettings = request.resource.data.get('settings', {});
        return oldSettings is map &&
            newSettings is map &&
            oldSettings.get('comprehensionRecording', null) ==
                newSettings.get('comprehensionRecording', null);
      }

      // No client `list`. A collection query returns full documents, and the
      // school doc holds cross-tenant org/billing data (address, contactEmail,
      // contactPhone, subscription, access). Any signed-in user could otherwise
      // enumerate every school (security finding #5). `get` stays member-scoped.
      // The only client that needed `list` was the login fallback for users
      // missing from userSchoolIndex; it now resolves the school server-side via
      // the resolveUserSchoolByUid callable (see login_screen.dart).
      // DEPLOY AFTER: functions:resolveUserSchoolByUid is live AND the app build
      // that uses it (removing the client /schools list) has shipped.
      allow list: if false;
      allow get: if belongsToSchool(schoolId) || isDevImpersonatingSchool(schoolId);

      allow create: if isSignedIn() &&
          request.resource.data.createdBy == request.auth.uid &&
          aiEvaluationSettingsAbsentOnCreate() &&
          comprehensionRecordingSettingsAbsentOnCreate() &&
          writeAllowedForDev();

      allow update: if isSchoolAdmin(schoolId) &&
          writeAllowedForDev() &&
          aiEvaluationSettingsUnchanged() &&
          comprehensionRecordingSettingsUnchanged();

      // Controlled counter increments for onboarding/registration lifecycle.
      allow update: if isSignedIn() &&
          writeAllowedForDev() &&
          request.resource.data.diff(resource.data).affectedKeys().size() == 1 &&
          (
            (
              request.resource.data.diff(resource.data).affectedKeys().hasOnly(['teacherCount']) &&
              request.resource.data.teacherCount == resource.data.teacherCount + 1 &&
              (isSchoolAdmin(schoolId) || isTeacher(schoolId))
            ) ||
            (
              request.resource.data.diff(resource.data).affectedKeys().hasOnly(['parentCount']) &&
              request.resource.data.parentCount == resource.data.parentCount + 1 &&
              (isSchoolAdmin(schoolId) || isParentMember(schoolId))
            ) ||
            (
              request.resource.data.diff(resource.data).affectedKeys().hasOnly(['studentCount']) &&
              request.resource.data.studentCount == resource.data.studentCount + 1 &&
              (isSchoolAdmin(schoolId) || isTeacher(schoolId))
            )
          );

      allow delete: if false;

      match /users/{userId} {
        allow get: if (isSignedIn() && request.auth.uid == userId) ||
            isSchoolAdmin(schoolId) ||
            isTeacher(schoolId) ||
            isDevImpersonatingSchool(schoolId);

        allow list: if isSchoolAdmin(schoolId) ||
            isTeacher(schoolId) ||
            isDevImpersonatingSchool(schoolId);

        // Teacher self-create was REMOVED (1.3). The legitimate teacher signup
        // writes this doc SERVER-SIDE via enrollLinkedPhoneAsMfa /
        // finalizeTeacher (Admin SDK, bypasses rules) after validating a school
        // code — no Flutter client SDK path creates a teacher doc. Self-create
        // let any account holder become a teacher of any school (isTeacher()
        // reads exactly this self-authored doc → all children's PII). The only
        // client creates that remain: an existing school admin provisioning
        // staff, and the first-admin bootstrap of a school they created.
        allow create: if isSignedIn() &&
            writeAllowedForDev() &&
            request.resource.data.schoolId == schoolId &&
            (
              isSchoolAdmin(schoolId) ||
              (
                request.auth.uid == userId &&
                request.resource.data.role == 'schoolAdmin' &&
                exists(/databases/$(database)/documents/schools/$(schoolId)) &&
                get(/databases/$(database)/documents/schools/$(schoolId)).data.createdBy == request.auth.uid
              )
            );

        // Self-updates restricted to a small set of user-owned fields.
        // Anything outside this list (rate limits, subscription/entitlement
        // state, role/permissions, MFA verification flags, etc.) must be
        // written exclusively from a trusted source (Admin SDK in Cloud
        // Functions or the super-admin backend), bypassing client rules.
        allow update: if isSignedIn() &&
            writeAllowedForSchoolContent(schoolId) &&
            (
              isSchoolAdmin(schoolId) ||
              (
                request.auth.uid == userId &&
                request.resource.data.role == resource.data.role &&
                request.resource.data.schoolId == resource.data.schoolId &&
                request.resource.data.diff(resource.data).affectedKeys().hasOnly([
                  'preferences',
                  'fcmToken',
                  'fcmTokenUpdatedAt',
                  'lastLoginAt',
                  'relationshipLabel',
                  // Profile mascot a staff member picks for themselves (app/portal).
                  // Category-vs-role (la_/mt_/ft_) is enforced by the write paths.
                  'characterId',
                  'termsAccepted',
                  'termsAcceptedAt',
                  'termsAcceptedVersion',
                  'termsAcceptedPlatform',
                ]) &&
                isValidTermsAcceptanceUpdate()
              )
            );

        allow delete: if isSchoolAdmin(schoolId) && writeAllowedForDev();
      }

      match /parents/{parentId} {
        allow get: if (isSignedIn() && request.auth.uid == parentId) ||
            isSchoolAdmin(schoolId) ||
            isTeacher(schoolId) ||
            isDevImpersonatingSchool(schoolId);

        allow list: if isSchoolAdmin(schoolId) ||
            isTeacher(schoolId) ||
            isDevImpersonatingSchool(schoolId);

        // Membership creation is server-only. Parent signup/linking callables
        // verify a live child code, then create the profile and linkedChildren
        // atomically with Admin SDK privileges. A bare signed-in account must
        // not be able to join an arbitrary known school id.
        allow create: if false;

        // Self-updates restricted to a small set of parent-owned fields.
        // Anything outside this list (rate limits, subscription/entitlement
        // state, role, MFA verification flags, linked-children mutations,
        // etc.) must be written exclusively from a trusted source (Admin SDK
        // in Cloud Functions or the super-admin backend).
        allow update: if isSignedIn() &&
            writeAllowedForSchoolContent(schoolId) &&
            (
              isSchoolAdmin(schoolId) ||
              (
                request.auth.uid == parentId &&
                request.resource.data.role == resource.data.role &&
                request.resource.data.schoolId == resource.data.schoolId &&
                request.resource.data.diff(resource.data).affectedKeys().hasOnly([
                  'preferences',
                  'fcmToken',
                  'fcmTokenUpdatedAt',
                  'lastLoginAt',
                  'relationshipLabel',
                  'termsAccepted',
                  'termsAcceptedAt',
                  'termsAcceptedVersion',
                  'termsAcceptedPlatform',
                ]) &&
                isValidTermsAcceptanceUpdate()
              )
            );

        allow delete: if isSchoolAdmin(schoolId) && writeAllowedForDev();

        match /notifications/{notificationId} {
          allow get, list: if (isSignedIn() && request.auth.uid == parentId) ||
              isDevImpersonatingSchool(schoolId);

          allow create: if false;

          // Parents may clear their own inbox (swipe-to-dismiss & Clear all).
          allow delete: if isSignedIn() &&
              writeAllowedForDev() &&
              request.auth.uid == parentId;

          allow update: if isSignedIn() &&
              writeAllowedForDev() &&
              request.auth.uid == parentId &&
              request.resource.data.diff(resource.data).affectedKeys().hasOnly(['isRead', 'readAt']) &&
              request.resource.data.campaignId == resource.data.campaignId &&
              request.resource.data.schoolId == resource.data.schoolId;
        }
      }

      match /students/{studentId} {
        allow get, list: if isSchoolAdmin(schoolId) ||
            isDevImpersonatingSchool(schoolId);

        allow get, list: if isTeacher(schoolId) &&
            teacherTeachesClass(schoolId, resource.data.classId);

        allow get: if isSignedIn() &&
            getUserData(schoolId).linkedChildren != null &&
            studentId in getUserData(schoolId).linkedChildren;

        allow create: if (isSchoolAdmin(schoolId) ||
              (isTeacher(schoolId) &&
                teacherTeachesClass(schoolId, request.resource.data.classId))) &&
            writeAllowedForDev() &&
            request.resource.data.schoolId == schoolId;

        // Staff may edit student profile / reading-level fields, but NOT the
        // server-owned `access` entitlement map (writing access.status='active'
        // would bypass the licensing gate) nor `parentIds` (owned by the parent
        // linking system / Admin SDK). Those are written only via Cloud
        // Functions (buildStudentAccess, linkParentToStudent), which bypass
        // rules. `access` is set legitimately server-side only.
        // `autoAward` is the weekly Top Reader award — written ONLY by the
        // topReaderAward Cloud Function (Admin SDK); clients must not spoof it.
        // (`manualAward`, the teacher's special award, is intentionally NOT
        // blocked — teachers set it from the app.)
        allow update: if (isSchoolAdmin(schoolId) ||
              (isTeacher(schoolId) &&
                teacherTeachesClass(schoolId, resource.data.classId) &&
                teacherTeachesClass(schoolId, request.resource.data.classId))) &&
            writeAllowedForDev() &&
            !request.resource.data.diff(resource.data).affectedKeys()
                .hasAny([
                  'access',
                  'parentIds',
                  'autoAward',
                  'pendingDeletion',
                  'pendingDeletionAt'
                ]);

        // Deletion is intentionally server-only. The requestStudentDeletion
        // callable re-checks role/class scope, requires recent authentication
        // and performs the full cross-collection/storage cascade. A direct
        // client delete would leave personal data and broken references behind.
        allow delete: if false;

        // Parent linking writes `parentIds` SERVER-SIDE only, via the
        // linkParentToStudent callable (Admin SDK, TOCTOU-safe code validation
        // — see parent_linking.ts). The old client self-append rule was REMOVED
        // (1.3): no client writes parentIds directly, and self-append (gated
        // only on "caller has a parent doc in the school") let any parent-doc
        // holder pollute an arbitrary student's parentIds without a valid link
        // code.

        // Profile character: a linked parent can set only their child's
        // characterId (the profile mascot they pick in-app).
        allow update: if isSignedIn() &&
            writeAllowedForDev() &&
            getUserData(schoolId).linkedChildren != null &&
            studentId in getUserData(schoolId).linkedChildren &&
            request.resource.data.diff(resource.data).affectedKeys().hasOnly(['characterId']);

        match /readingLevelEvents/{eventId} {
          allow get, list: if isSchoolAdmin(schoolId) ||
              isDevImpersonatingSchool(schoolId);

          allow get, list: if isTeacher(schoolId) &&
              teacherTeachesClass(
                schoolId,
                get(/databases/$(database)/documents/schools/$(schoolId)/students/$(studentId)).data.classId
              );

          allow create: if (isSchoolAdmin(schoolId) ||
                (isTeacher(schoolId) &&
                  teacherTeachesClass(
                    schoolId,
                    get(/databases/$(database)/documents/schools/$(schoolId)/students/$(studentId)).data.classId
                  ))) &&
              writeAllowedForDev();
          allow update, delete: if false;
        }
      }

      match /classes/{classId} {
        allow get, list: if isSchoolAdmin(schoolId) || isDevImpersonatingSchool(schoolId);

        allow get, list: if isTeacher(schoolId) &&
            (resource.data.teacherId == request.auth.uid ||
                (resource.data.teacherIds != null &&
                    request.auth.uid in resource.data.teacherIds));

        allow get, list: if isSignedIn() &&
            getUserData(schoolId).linkedChildren != null &&
            resource.data.studentIds.hasAny(getUserData(schoolId).linkedChildren);

        allow create, delete: if isSchoolAdmin(schoolId) && writeAllowedForDev();

        allow update: if writeAllowedForSchoolContent(schoolId) &&
            (
              isSchoolAdmin(schoolId) ||
              (isTeacher(schoolId) &&
                  (resource.data.teacherId == request.auth.uid ||
                      (resource.data.teacherIds != null &&
                          request.auth.uid in resource.data.teacherIds)))
            );
      }

      match /readingLogs/{logId} {
        // Minutes must be a sane integer. Every legit client sends 5-120;
        // validateReadingLog flags 1-240 violations after the fact, but the
        // aggregators shouldn't have to rely on that for obviously forged
        // writes. Checked on create AND content updates (a log could
        // otherwise be created valid and edited to 99999 later).
        function minutesInBounds() {
          return request.resource.data.minutesRead is int &&
              request.resource.data.minutesRead >= 1 &&
              request.resource.data.minutesRead <= 240;
        }

        function isQuickLogCreate() {
          return request.resource.data.get('metadata', {}) is map &&
              request.resource.data.get('metadata', {}).get('quickLog', false) == true;
        }

        function incomingStudentData() {
          return get(
            /databases/$(database)/documents/schools/$(schoolId)/students/$(request.resource.data.studentId)
          ).data;
        }

        function createSchemaIsValid() {
          let data = request.resource.data;
          let student = incomingStudentData();
          return data.keys().hasAll([
              'studentId', 'parentId', 'schoolId', 'classId', 'date',
              'minutesRead', 'targetMinutes', 'status', 'bookTitles',
              'createdAt'
            ]) &&
            data.keys().hasOnly([
              'studentId', 'parentId', 'schoolId', 'classId', 'date',
              'minutesRead', 'targetMinutes', 'status', 'bookTitles',
              'notes', 'photoUrls', 'isOfflineCreated', 'createdAt',
              'syncedAt', 'allocationId', 'metadata', 'childFeeling',
              'parentComment', 'parentCommentSelections',
              'parentCommentFreeText', 'loggedByName', 'loggedByLabel',
              'loggedByRole'
            ]) &&
            data.schoolId == schoolId &&
            data.studentId is string && data.studentId.size() > 0 &&
            data.parentId is string && data.parentId.size() > 0 &&
            data.classId is string && data.classId.size() > 0 &&
            student.schoolId == schoolId &&
            student.classId == data.classId &&
            data.date is timestamp &&
            data.date >= request.time - duration.value(366, 'd') &&
            data.date <= request.time + duration.value(1, 'd') &&
            data.createdAt == request.time &&
            data.targetMinutes is int &&
            data.targetMinutes >= 1 && data.targetMinutes <= 240 &&
            data.status in ['completed', 'partial', 'skipped', 'pending'] &&
            data.bookTitles is list && data.bookTitles.size() <= 20 &&
            (data.get('notes', null) == null ||
              (data.notes is string && data.notes.size() <= 2000)) &&
            (data.get('childFeeling', null) == null ||
              data.childFeeling in ['hard', 'tricky', 'okay', 'good', 'great']) &&
            (data.get('photoUrls', null) == null ||
              (data.photoUrls is list && data.photoUrls.size() <= 5)) &&
            (data.get('isOfflineCreated', null) == null ||
              data.isOfflineCreated is bool) &&
            (data.get('syncedAt', null) == null ||
              data.syncedAt is timestamp) &&
            (data.get('allocationId', null) == null ||
              (data.allocationId is string && data.allocationId.size() <= 200)) &&
            (data.get('metadata', null) == null ||
              (data.metadata is map &&
                data.metadata.keys().hasOnly(['quickLog']) &&
                data.metadata.get('quickLog', false) is bool)) &&
            (data.get('parentCommentSelections', null) == null ||
              (data.parentCommentSelections is list &&
                data.parentCommentSelections.size() <= 10)) &&
            (data.get('parentComment', null) == null ||
              (data.parentComment is string && data.parentComment.size() <= 2000)) &&
            (data.get('parentCommentFreeText', null) == null ||
              (data.parentCommentFreeText is string &&
                data.parentCommentFreeText.size() <= 2000)) &&
            (data.get('loggedByName', null) == null ||
              (data.loggedByName is string && data.loggedByName.size() <= 200)) &&
            (data.get('loggedByLabel', null) == null ||
              (data.loggedByLabel is string && data.loggedByLabel.size() <= 200)) &&
            (data.get('loggedByRole', null) == null ||
              data.loggedByRole in ['parent', 'teacher']);
        }

        function contentUpdateIsValid() {
          let changed = request.resource.data.diff(resource.data).affectedKeys();
          let data = request.resource.data;
          return changed.hasOnly([
              'minutesRead', 'targetMinutes', 'bookTitles', 'notes',
              'photoUrls', 'childFeeling', 'parentComment',
              'parentCommentSelections', 'parentCommentFreeText',
              'syncedAt', 'isOfflineCreated'
            ]) &&
            minutesInBounds() &&
            data.targetMinutes is int &&
            data.targetMinutes >= 1 && data.targetMinutes <= 240 &&
            data.bookTitles is list && data.bookTitles.size() <= 20 &&
            (data.get('notes', null) == null ||
              (data.notes is string && data.notes.size() <= 2000)) &&
            (data.get('photoUrls', null) == null ||
              (data.photoUrls is list && data.photoUrls.size() <= 5)) &&
            (data.get('childFeeling', null) == null ||
              data.childFeeling in ['hard', 'tricky', 'okay', 'good', 'great']) &&
            (data.get('parentCommentSelections', null) == null ||
              (data.parentCommentSelections is list &&
                data.parentCommentSelections.size() <= 10)) &&
            (data.get('parentComment', null) == null ||
              (data.parentComment is string && data.parentComment.size() <= 2000)) &&
            (data.get('parentCommentFreeText', null) == null ||
              (data.parentCommentFreeText is string &&
                data.parentCommentFreeText.size() <= 2000));
        }

        function threadPreviewUpdateIsValid() {
          let changed = request.resource.data.diff(resource.data).affectedKeys();
          let role = request.resource.data.lastCommentByRole;
          return changed.hasOnly([
              'lastCommentPreview', 'lastCommentAt', 'lastCommentByRole'
            ]) &&
            request.resource.data.lastCommentPreview is string &&
            request.resource.data.lastCommentPreview.size() > 0 &&
            request.resource.data.lastCommentPreview.size() <= 2000 &&
            request.resource.data.lastCommentAt is timestamp &&
            request.resource.data.lastCommentAt <= request.time &&
            request.resource.data.lastCommentAt >=
              request.time - duration.value(7, 'd') &&
            role in ['parent', 'teacher'] &&
            (
              (role == 'parent' && resource.data.parentId == request.auth.uid) ||
              (role == 'teacher' &&
                (isSchoolAdmin(schoolId) ||
                  teacherTeachesClass(schoolId, resource.data.classId)))
            );
        }

        allow get, list: if isSchoolAdmin(schoolId) ||
            isDevImpersonatingSchool(schoolId);

        allow get, list: if isTeacher(schoolId) &&
            teacherTeachesClass(schoolId, resource.data.classId);

        allow get, list: if isSignedIn() &&
            getUserData(schoolId).linkedChildren != null &&
            resource.data.studentId in getUserData(schoolId).linkedChildren;

        // The parent logging path is the revenue/usage write and the single
        // enforcement point for entitlement. One get() of the student doc (low
        // volume — once per log) gates it on live access: if the child's access
        // has lapsed (non-renewal) or been suspended (unpaid/off-boarded school
        // — the trigger cascades status to 'suspended'), the write is DENIED.
        // Student READS are intentionally left open so the app can read
        // `access` to render the "access lapsed — contact your school" screen.
        // Parent logs and teacher-proxy logs share one schema/access evaluation.
        // Keeping this as a single allow avoids evaluating the expensive schema
        // twice (Firestore caps a request at 1,000 rule expressions).
        // Teacher proxy logs: a teacher logs reading on behalf of a student
        // whose carer can't use the app. `parentId` holds the teacher's UID
        // (creator) so the existing ownership clauses in update/delete keep
        // working. `loggedByRole == 'teacher'` is the explicit proxy signal
        // and stops a teacher accidentally writing a parent-shaped log.
        // Membership is verified against the class document's teacher
        // assignment (see teacherTeachesClass) — the denormalised
        // `classIds` on the teacher's user doc is created empty and never
        // synced by the portal, so relying on it denied every proxy log.
        allow create: if isSignedIn() &&
            writeAllowedForSchoolContent(schoolId) &&
            createSchemaIsValid() &&
            minutesInBounds() &&
            studentAccessLive(
              get(/databases/$(database)/documents/schools/$(schoolId)/students/$(request.resource.data.studentId)).data
            ) &&
            (
              (
                (!isQuickLogCreate() || quickLoggingEnabled(schoolId)) &&
                getUserData(schoolId).linkedChildren != null &&
                request.resource.data.studentId in getUserData(schoolId).linkedChildren &&
                request.resource.data.parentId == request.auth.uid &&
                (
                  request.resource.data.get('loggedByRole', null) == null ||
                  request.resource.data.loggedByRole == 'parent'
                )
              ) ||
              (
                isTeacher(schoolId) &&
                request.resource.data.parentId == request.auth.uid &&
                request.resource.data.loggedByRole == 'teacher' &&
                teacherTeachesClass(schoolId, request.resource.data.classId)
              )
            );

        allow update: if writeAllowedForSchoolContent(schoolId) &&
            contentUpdateIsValid() &&
            (
              (isSignedIn() && resource.data.parentId == request.auth.uid) ||
              isSchoolAdmin(schoolId) ||
              (isTeacher(schoolId) &&
                teacherTeachesClass(schoolId, resource.data.classId))
            );

        allow update: if writeAllowedForSchoolContent(schoolId) &&
            isSignedIn() &&
            threadPreviewUpdateIsValid();

        // A linked parent who didn't create the log (a co-carer, or someone
        // viewing a teacher-proxy log for their child) may still clear their
        // own unread badge. Scoped tightly: the only field they can touch is
        // `commentsViewedAt`, and within it only their own uid key — so a
        // non-owner can't edit log content or another carer's read marker.
        allow update: if writeAllowedForSchoolContent(schoolId) &&
            isSignedIn() &&
            getUserData(schoolId).linkedChildren != null &&
            resource.data.studentId in getUserData(schoolId).linkedChildren &&
            request.resource.data.diff(resource.data)
                .affectedKeys().hasOnly(['commentsViewedAt']) &&
            request.resource.data.commentsViewedAt
                .diff(resource.data.get('commentsViewedAt', {}))
                .affectedKeys().hasOnly([request.auth.uid]);

        // Parent can delete a log they created (powers the widget-undo
        // banner). Stats are reconciled by the aggregateStudentStats Cloud
        // Function on log delete, so no client-side stats write is needed.
        allow delete: if writeAllowedForSchoolContent(schoolId) &&
            (
              isSchoolAdmin(schoolId) ||
              (isSignedIn() && resource.data.parentId == request.auth.uid)
            );

        // Threaded comments. `studentId` is denormalized onto each comment so
        // these rules mirror the parent/teacher access on the parent log
        // without an extra get() to read it.
        match /comments/{commentId} {
          function parentLogData() {
            return get(
              /databases/$(database)/documents/schools/$(schoolId)/readingLogs/$(logId)
            ).data;
          }

          function commentSchemaIsValid() {
            let data = request.resource.data;
            let log = parentLogData();
            return data.keys().hasAll([
                'authorId', 'authorRole', 'authorName', 'body', 'createdAt',
                'studentId', 'parentId'
              ]) &&
              data.keys().hasOnly([
                'authorId', 'authorRole', 'authorName', 'body', 'createdAt',
                'studentId', 'parentId'
              ]) &&
              data.authorId == request.auth.uid &&
              data.authorRole in ['parent', 'teacher'] &&
              data.authorName is string && data.authorName.size() > 0 &&
              data.authorName.size() <= 200 &&
              data.body is string && data.body.size() > 0 &&
              data.body.size() <= 2000 &&
              data.createdAt == request.time &&
              data.studentId == log.studentId &&
              data.parentId == log.parentId &&
              log.schoolId == schoolId;
          }

          allow get, list: if isSchoolAdmin(schoolId) ||
              isDevImpersonatingSchool(schoolId);

          allow get, list: if isTeacher(schoolId) &&
              teacherTeachesClass(schoolId, parentLogData().classId);

          allow get, list: if isSignedIn() &&
              getUserData(schoolId).linkedChildren != null &&
              resource.data.studentId in getUserData(schoolId).linkedChildren;

          // Teachers post as staff; parents post on their own child's log.
          // authorId is pinned to the caller so attribution can't be spoofed.
          // messagingEnabled() is the server-side backstop to the app-side gate:
          // a school that has turned parent↔teacher messaging off can't have new
          // threads created regardless of client state.
          allow create: if writeAllowedForSchoolContent(schoolId) &&
              messagingEnabled(schoolId) &&
              commentSchemaIsValid() &&
              (
                (isTeacher(schoolId) &&
                    request.resource.data.authorRole == 'teacher' &&
                    teacherTeachesClass(schoolId, parentLogData().classId)) ||
                (isSignedIn() &&
                    request.resource.data.authorRole == 'parent' &&
                    getUserData(schoolId).linkedChildren != null &&
                    request.resource.data.studentId in
                        getUserData(schoolId).linkedChildren)
              );

          // Comments are immutable; edits/deletes are denied (default).
        }
      }

      // Server-owned, sharded class/day aggregates. Teachers must constrain
      // list queries to a class they teach; no client can alter projections or
      // totals. `readingLogSummaryState` is internal idempotency state and is
      // never exposed, including to school admins.
      match /classDailyReading/{summaryId} {
        allow get, list: if isSchoolAdmin(schoolId) ||
            isDevImpersonatingSchool(schoolId);

        allow get, list: if isTeacher(schoolId) &&
            teacherTeachesClass(schoolId, resource.data.classId);

        allow create, update, delete: if false;
      }

      match /readingLogSummaryState/{logId} {
        allow read, write: if false;
      }

      match /allocations/{allocationId} {
        allow get, list: if isSchoolAdmin(schoolId) ||
            (isTeacher(schoolId) &&
              teacherTeachesClass(schoolId, resource.data.classId)) ||
            parentCanReadAllocation(schoolId, resource.data) ||
            isDevImpersonatingSchool(schoolId);

        allow create: if (isSchoolAdmin(schoolId) ||
              (isTeacher(schoolId) &&
                teacherTeachesClass(schoolId, request.resource.data.classId))) &&
            request.resource.data.schoolId == schoolId &&
            (
              writeAllowedForDev() ||
              (demoAccountMayWriteSchoolContent(schoolId) &&
                validCurrentDemoAllocation(schoolId, request.resource.data))
            );

        allow update: if (isSchoolAdmin(schoolId) ||
              (isTeacher(schoolId) &&
                teacherTeachesClass(schoolId, resource.data.classId) &&
                teacherTeachesClass(schoolId, request.resource.data.classId))) &&
            request.resource.data.schoolId == schoolId &&
            (
              writeAllowedForDev() ||
              (demoAccountMayWriteSchoolContent(schoolId) &&
                validCurrentDemoAllocation(schoolId, resource.data) &&
                validCurrentDemoAllocation(schoolId, request.resource.data) &&
                request.resource.data.demoGenerationId ==
                  resource.data.demoGenerationId &&
                request.resource.data.demoOrigin == resource.data.demoOrigin)
            );

        allow delete: if (isSchoolAdmin(schoolId) ||
              (isTeacher(schoolId) &&
                teacherTeachesClass(schoolId, resource.data.classId))) &&
            (
              writeAllowedForDev() ||
              (demoAccountMayWriteSchoolContent(schoolId) &&
                validCurrentDemoAllocation(schoolId, resource.data))
            );
      }

      match /books/{bookId} {
        // Any school member can read school-scoped book metadata.
        allow get, list: if belongsToSchool(schoolId) || isDevImpersonatingSchool(schoolId);

        // Only teachers and admins can add/update books (parents cannot write)
        allow create, update: if (isSchoolAdmin(schoolId) || isTeacher(schoolId)) &&
            writeAllowedForSchoolContent(schoolId) &&
            request.resource.data.schoolId == schoolId;

        allow delete: if isSchoolAdmin(schoolId) &&
            writeAllowedForSchoolContent(schoolId);
      }

      match /readingGroups/{groupId} {
        allow get, list: if isSchoolAdmin(schoolId) ||
            (isTeacher(schoolId) &&
              teacherTeachesClass(schoolId, resource.data.classId)) ||
            (isParentMember(schoolId) &&
              resource.data.studentIds is list &&
              resource.data.studentIds.hasAny(linkedChildrenForSchool(schoolId))) ||
            isDevImpersonatingSchool(schoolId);

        allow create: if (isSchoolAdmin(schoolId) ||
              (isTeacher(schoolId) &&
                teacherTeachesClass(schoolId, request.resource.data.classId))) &&
            writeAllowedForSchoolContent(schoolId) &&
            request.resource.data.schoolId == schoolId;

        allow update: if (isSchoolAdmin(schoolId) ||
              (isTeacher(schoolId) &&
                teacherTeachesClass(schoolId, resource.data.classId) &&
                teacherTeachesClass(schoolId, request.resource.data.classId))) &&
            writeAllowedForSchoolContent(schoolId) &&
            request.resource.data.schoolId == schoolId;

        allow delete: if (isSchoolAdmin(schoolId) ||
              (isTeacher(schoolId) &&
                teacherTeachesClass(schoolId, resource.data.classId))) &&
            writeAllowedForSchoolContent(schoolId);
      }

      match /notificationCampaigns/{campaignId} {
        allow get, list: if isSchoolAdmin(schoolId) ||
            (isTeacher(schoolId) && resource.data.createdBy == request.auth.uid) ||
            isDevImpersonatingSchool(schoolId);

        allow create, update, delete: if false;
      }

      match /parentOnboardingEmails/{emailId} {
        allow get, list: if isSchoolAdmin(schoolId) || isDevImpersonatingSchool(schoolId);
        allow create: if isSchoolAdmin(schoolId)
            && writeAllowedForDev()
            && request.resource.data.status == 'queued'
            && request.resource.data.schoolId == schoolId;
        allow update, delete: if false;
      }

      match /staffOnboardingEmails/{emailId} {
        allow get, list: if isSchoolAdmin(schoolId) || isDevImpersonatingSchool(schoolId);
        allow create: if isSchoolAdmin(schoolId)
            && writeAllowedForDev()
            && request.resource.data.status == 'queued'
            && request.resource.data.schoolId == schoolId;
        allow update, delete: if false;
      }

      // Plaintext temporary passwords for admin-imported staff. Admin-SDK
      // only (the credentials API and the email Cloud Function) — never
      // readable by any client, including the staff member themselves.
      match /staffCredentials/{userId} {
        allow read, write: if false;
      }

      // AI-generated evaluations are deliberately separated from parent-
      // readable readingLogs. Teachers must prove class scope in the query;
      // school admins and live read-only impersonation sessions may inspect
      // the school. All writes are performed by trusted Admin SDK workers.
      match /comprehensionEvals/{logId} {
        allow get, list: if isSchoolAdmin(schoolId) ||
            isDevImpersonatingSchool(schoolId);

        allow get, list: if isTeacher(schoolId) &&
            teacherTeachesClass(schoolId, resource.data.classId);

        allow create, update, delete: if false;
      }

      // Commercial entitlements and per-school caps are never visible to
      // school members. The super-admin portal and workers use Admin SDK.
      match /adminMeta/{docId} {
        allow read, write: if false;
      }
    }

    // ── Community Book Database (global, cross-school) ──────────────
    // Shared catalog that any teacher/admin can contribute to.
    // No client-side delete — only Admin SDK from the super-admin backend.
    match /community_books/{isbn} {
      // Any authenticated user can read community books.
      allow get, list: if isSignedIn();

      // Only teachers and school admins can create new entries.
      // The contributor must declare their schoolId so the role check can verify.
      allow create: if isSignedIn()
          && writeAllowedForDev()
          && request.resource.data.contributedBySchoolId is string
          && request.resource.data.contributedBySchoolId.size() > 0
          && (isTeacher(request.resource.data.contributedBySchoolId)
              || isSchoolAdmin(request.resource.data.contributedBySchoolId))
          && request.resource.data.contributedBy == request.auth.uid;

      // Teachers/admins can update (improve metadata, add cover).
      // The original contributedBy field is immutable.
      allow update: if isSignedIn()
          && writeAllowedForDev()
          && request.resource.data.contributedBy == resource.data.contributedBy
          && request.resource.data.contributedBySchoolId is string
          && (isTeacher(request.resource.data.contributedBySchoolId)
              || isSchoolAdmin(request.resource.data.contributedBySchoolId));

      // No client-side delete.
      allow delete: if false;

      // Future: deletion request subcollection.
      match /deletionRequests/{requestId} {
        allow create: if isSignedIn()
            && writeAllowedForDev()
            && request.resource.data.requestedBy == request.auth.uid
            && request.resource.data.schoolId is string
            && (isTeacher(request.resource.data.schoolId)
                || isSchoolAdmin(request.resource.data.schoolId));

        // Only readable/manageable via Admin SDK.
        allow get, list, update, delete: if false;
      }
    }

    // Legacy top-level books collection (read-only migration fallback).
    match /books/{bookId} {
      allow get, list: if isSignedIn() &&
          resource.data.schoolId != null &&
          belongsToSchool(resource.data.schoolId);

      allow create, update, delete: if false;
    }

    match /users/{userId} {
      allow get: if isSignedIn() && request.auth.uid == userId;
      // Legacy profiles are server-owned. Keep only the narrow terms-consent
      // update needed while old accounts are migrated to school membership
      // documents; identity, role and tenant fields cannot be introduced or
      // changed by the client.
      allow update: if isSignedIn() &&
          request.auth.uid == userId &&
          writeAllowedForDev() &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly([
            'termsAccepted', 'termsAcceptedAt', 'termsAcceptedVersion',
            'termsAcceptedPlatform'
          ]) &&
          request.resource.data.termsAccepted == true &&
          request.resource.data.termsAcceptedAt == request.time &&
          request.resource.data.termsAcceptedVersion is string &&
          request.resource.data.termsAcceptedVersion.size() > 0 &&
          request.resource.data.termsAcceptedVersion.size() <= 40 &&
          request.resource.data.termsAcceptedPlatform in [
            'web', 'ios', 'android', 'macos', 'windows', 'linux', 'fuchsia'
          ];
      allow create, delete: if false;
    }

    match /schoolOnboarding/{onboardingId} {
      // Public requests go through submitDemoRequest, which applies App Check
      // rollout settings, durable rate limits, schema/size checks and trusted
      // timestamps. Provisioning/status changes are server/admin-only.
      allow read, write: if false;
    }

    // Durable unauthenticated school/student code-attempt counters. Only
    // callable Admin SDK code may observe or mutate them.
    match /publicCodeVerificationRateLimits/{counterId} {
      allow read, write: if false;
    }

    // Idempotent server-side teacher-code redemption receipts. These bind one
    // code use to one Auth UID and make max-usage enforcement retry-safe.
    match /schoolCodeRedemptions/{redemptionId} {
      allow read, write: if false;
    }

    match /studentLinkCodes/{codeId} {
      // Verification is server-side only: the verifyStudentLinkCode /
      // linkParentToStudent / createCoParentInvite callables (Admin SDK) look
      // codes up by exact value. There is deliberately NO unauthenticated
      // `list` rule — a bounded unauthenticated list let anyone paginate and
      // harvest every child-link code.

      allow get: if isSignedIn() &&
          (
            isSchoolAdmin(resource.data.schoolId) ||
            isTeacher(resource.data.schoolId) ||
            resource.data.usedBy == request.auth.uid
          );

      allow list: if isSignedIn() &&
          (
            isSchoolAdmin(resource.data.schoolId) ||
            isTeacher(resource.data.schoolId) ||
            resource.data.usedBy == request.auth.uid
          );

      // Creation, redemption, revocation and deletion all pass through
      // tenant-authorised Admin SDK callables/portal routes. No mobile client
      // may mint, consume or mutate this credential directly.
      allow create, update, delete: if false;
    }

    match /notifications/{notificationId} {
      allow read, write: if false;
    }

    match /schoolCodes/{codeId} {
      // Teacher registration validation is server-side only: the
      // verifySchoolCode callable (Admin SDK) looks a code up by exact value.
      // There is deliberately NO unauthenticated `list` rule — a bounded
      // unauthenticated list let anyone paginate and harvest every active
      // school join code (feeding self-provision-as-teacher).

      allow get: if isSignedIn() &&
          (
            isSchoolAdmin(resource.data.schoolId) ||
            isTeacher(resource.data.schoolId)
          );

      allow list: if isSignedIn() &&
          (
            isSchoolAdmin(resource.data.schoolId) ||
            isTeacher(resource.data.schoolId)
          );

      // Generation/rotation and retry-safe usage consumption are server-owned.
      // This also prevents a teacher from incrementing usage repeatedly to
      // exhaust a shared code and deny access to other legitimate staff.
      allow create, update, delete: if false;
    }

    // ── User Feedback ──────────────────────────────────────────────
    match /feedback/{feedbackId} {
      // Any signed-in user can submit feedback.
      allow create: if isSignedIn() &&
          writeAllowedForDev() &&
          request.resource.data.userId == request.auth.uid;

      // Read/update/delete only via Admin SDK (super-admin dashboard).
      allow get, list, update, delete: if false;
    }

    // pendingUserDeletions is written/read exclusively via Admin SDK (Cloud Function).
    // No client access permitted.
    match /pendingUserDeletions/{userId} {
      allow read, write: if false;
    }

    // Resumable account/student deletion jobs contain internal identifiers,
    // retry state and audit metadata. Status is exposed only through the
    // requester-bound getMyDeletionStatus callable.
    match /deletionJobs/{jobId} {
      allow read, write: if false;
    }

    match /userSchoolIndex/{emailHash} {
      allow get: if isSignedIn() && resource.data.userId == request.auth.uid;

      allow create: if isSignedIn() &&
          writeAllowedForDev() &&
          request.resource.data.userId == request.auth.uid;

      allow update: if isSignedIn() &&
          writeAllowedForDev() &&
          resource.data.userId == request.auth.uid &&
          request.resource.data.userId == request.auth.uid;

      allow delete: if isSignedIn() &&
          writeAllowedForDev() &&
          resource.data.userId == request.auth.uid;

      allow list: if false;
    }

    // O(1) login fallback maintained only by server-side membership triggers.
    // Clients do not need to know whether an arbitrary UID belongs to a school.
    match /userMembershipIndex/{uid} {
      allow read, write: if false;
    }

    // Dev-access allowlist is server-only. Mobile self-checks go through the
    // checkDevAccess callable, which derives the lookup hash from the verified
    // Auth token email and therefore cannot be used as an email oracle.
    match /devAccessEmails/{emailHash} {
      allow read, write: if false;
    }

    // AI evaluation pipeline state is server-only. Cloud Functions use the
    // Admin SDK; no mobile/web client may inspect, forge or mutate jobs,
    // prompt-classification cache entries, or provider/cost configuration.
    match /aiEvalJobs/{jobId} {
      allow read, write: if false;
    }

    match /aiQuestionClassifications/{classificationId} {
      allow read, write: if false;
    }

    match /aiEvalOpsConfig/{configId} {
      allow read, write: if false;
    }

    // ── Platform-wide feature flags ─────────────────────────────────
    // Written exclusively by the super-admin portal via the Admin SDK
    // (e.g. the comprehension-recording kill switch at
    // platformConfig/comprehensionRecording). Signed-in clients may
    // `get` individual flags to compute effective feature state; a
    // missing doc means the feature is enabled. Listing is denied.
    match /platformConfig/{flagId} {
      allow get: if isSignedIn();
      allow list, create, update, delete: if false;
    }

    // ── Ops metrics (admin-only telemetry) ──────────────────────────
    // Written by Cloud Functions (storage-usage triggers + cron
    // heartbeats), read only by the super-admin portal — both via the
    // Admin SDK, which bypasses rules. Unlike platformConfig, these docs
    // carry per-school telemetry (byte counts per school), so clients
    // get no access at all.
    match /opsMetrics/{docId} {
      allow read, write: if false;
    }

    // ── Super-admin allowlist ───────────────────────────────────────
    // Doc ID is the Firebase UID. Presence of a doc grants super-admin
    // power (revoke impersonation sessions, export audit logs). No
    // self-reads; only the Admin SDK inside Cloud Functions consults
    // this. Seeded manually via the Firebase console.
    match /superAdmins/{uid} {
      allow read, write: if false;
    }

    // ── Developer impersonation sessions ────────────────────────────
    // Lifecycle (create, status transitions) is owned by Cloud Functions
    // via the Admin SDK. Dev clients may `get` their own active session
    // so they can react when a super-admin revokes it.
    match /devImpersonationSessions/{sessionId} {
      allow get: if isSignedIn() && resource.data.devUid == request.auth.uid;
      allow list, create, update, delete: if false;
    }

    // ── Developer impersonation audit trail (append-only) ───────────
    // Entirely closed to clients. Only Cloud Functions write (via
    // Admin SDK) and only lumi-admin reads (via Admin SDK in server
    // routes). This keeps the log tamper-resistant.
    match /devImpersonationAudit/{eventId} {
      allow read, write: if false;
    }

    // ── Developer impersonation rate-limit counters ─────────────────
    // Per-developer counters for session-start throttling. Cloud
    // Functions only.
    match /devImpersonationRateLimits/{devUid} {
      allow read, write: if false;
    }

    // ── Demo-day rolling access (state) ─────────────────────────────
    // demoAccess/state holds the plaintext day password for the shared
    // sales-demo school. Written by the super-admin portal (Admin SDK)
    // and read by Cloud Functions (email trigger + scramble cron) only —
    // never by any client. Same plaintext-password precedent as
    // schools/{id}/staffCredentials.
    match /demoAccess/{docId} {
      allow read, write: if false;
    }

    // ── Demo-day access emails (queue + permanent paper trail) ──────
    // Written by the portal (Admin SDK) and consumed by the
    // processDemoAccessEmail trigger; the docs are kept forever as the
    // canonical "who was given demo access" record and rendered in the
    // portal via Admin SDK reads. Entirely closed to clients.
    match /demoAccessEmails/{docId} {
      allow read, write: if false;
    }
  }
}
