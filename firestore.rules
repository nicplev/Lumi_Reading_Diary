rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Healthcheck doc read by every client every ~30s as the L3 probe.
    // Tiny, public to signed-in users, never written from the client.
    // Seed once via an admin script: `_meta/healthcheck = { version: 1 }`.
    match /_meta/healthcheck {
      allow read: if request.auth != null;
      allow write: if false;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function getUserData(schoolId) {
      let userPath = /databases/$(database)/documents/schools/$(schoolId)/users/$(request.auth.uid);
      let parentPath = /databases/$(database)/documents/schools/$(schoolId)/parents/$(request.auth.uid);

      return exists(userPath)
          ? get(userPath).data
          : exists(parentPath)
              ? get(parentPath).data
              : null;
    }

    function userRole(schoolId) {
      let userData = getUserData(schoolId);
      return userData == null ? null : userData.role;
    }

    function isSchoolAdmin(schoolId) {
      return isSignedIn() && userRole(schoolId) == 'schoolAdmin';
    }

    function isTeacher(schoolId) {
      return isSignedIn() && userRole(schoolId) == 'teacher';
    }

    function isParentMember(schoolId) {
      return isSignedIn() && userRole(schoolId) == 'parent';
    }

    function belongsToSchool(schoolId) {
      return isSignedIn() &&
          (exists(/databases/$(database)/documents/schools/$(schoolId)/users/$(request.auth.uid)) ||
              exists(/databases/$(database)/documents/schools/$(schoolId)/parents/$(request.auth.uid)));
    }

    function linkedChildrenForSchool(schoolId) {
      let userData = getUserData(schoolId);
      return userData == null || userData.linkedChildren == null
          ? []
          : userData.linkedChildren;
    }

    function classContainsLinkedChildren(schoolId, classId, linkedChildren) {
      return classId != null &&
          exists(/databases/$(database)/documents/schools/$(schoolId)/classes/$(classId)) &&
          get(/databases/$(database)/documents/schools/$(schoolId)/classes/$(classId)).data.studentIds.hasAny(linkedChildren);
    }

    // Does the signed-in teacher own/co-teach `classId`? The class document's
    // teacherId/teacherIds is the single source of truth for the teacher↔class
    // relationship (it's what every other class rule and the portal's
    // class-by-teacher query use). Checking it here — rather than a denormalised
    // `classIds` on the teacher's user doc, which the school portal never keeps
    // in sync on class create/update — is what keeps teacher-proxy logging working.
    function teacherTeachesClass(schoolId, classId) {
      let classPath = /databases/$(database)/documents/schools/$(schoolId)/classes/$(classId);
      return classId is string &&
          classId != '' &&
          exists(classPath) &&
          (
            get(classPath).data.get('teacherId', '') == request.auth.uid ||
            request.auth.uid in get(classPath).data.get('teacherIds', [])
          );
    }

    function parentCanReadAllocation(schoolId, allocationData) {
      let linkedChildren = linkedChildrenForSchool(schoolId);

      return isParentMember(schoolId) &&
          linkedChildren.size() > 0 &&
          allocationData.studentIds != null &&
          (
            allocationData.studentIds.hasAny(linkedChildren) ||
            (
              allocationData.studentIds.size() == 0 &&
              classContainsLinkedChildren(
                schoolId,
                allocationData.classId,
                linkedChildren,
              )
            )
          );
    }

    // ── Access / entitlement helper ─────────────────────────────────
    // Fail-closed verdict for a student's materialised `access` map. Live
    // only when status == 'active' AND the absolute hard-expiry is still in
    // the future. Safe `.get(key, default)` accessors make a missing `access`
    // map (legacy docs) evaluate to DENIED rather than raising: an absent
    // status defaults to '' (≠ 'active'), and an absent expiresAt defaults to
    // request.time (so `> request.time` is false). The expiresAt comparison is
    // the date-driven backstop — access lapses on schedule even if no Cloud
    // Function ever runs. school-wide suspension flows through here too: the
    // subscription trigger flips each student's access.status to 'suspended'.
    function studentAccessLive(studentData) {
      return studentData.get('access', {}).get('status', '') == 'active' &&
          studentData.get('access', {}).get('expiresAt', request.time) > request.time;
    }

    // ── Developer impersonation helpers ─────────────────────────────
    // An allowlisted developer can start a short-lived impersonation
    // session via a Cloud Function, which mints a custom token carrying
    // these claims. The claims widen read access to a single target
    // school and hard-block every write path (devReadOnly).
    //
    // All claim reads use `.get(key, default)` so that normal (non-dev)
    // sessions — where these claims are absent — evaluate the helpers
    // cleanly to `false` instead of raising "property undefined".
    function isDevImpersonating() {
      return request.auth != null
          && request.auth.token.get('devImpersonating', false) == true
          && request.auth.token.get('impersonationSessionId', '') is string
          && request.auth.token.get('impersonationSessionId', '').size() > 0;
    }

    // Reads the live session doc named by the token's sessionId claim and
    // confirms it is still active, targets THIS school, and hasn't expired.
    // This is what makes super-admin revocation and the 30-min TTL take effect
    // immediately: the claims alone would otherwise keep granting read access
    // for the full ~1h ID-token lifetime, outliving the session. Costs one
    // get() per impersonated read (dev-only, low volume); normal users never
    // reach it because isDevImpersonating() short-circuits to false first.
    function impersonationSessionLive(schoolId) {
      let sid = request.auth.token.get('impersonationSessionId', '');
      let session = get(/databases/$(database)/documents/devImpersonationSessions/$(sid));
      return session != null
          && session.data.status == 'active'
          && session.data.targetSchoolId == schoolId
          && request.time < session.data.expiresAt;
    }

    function isDevImpersonatingSchool(schoolId) {
      return isDevImpersonating()
          && request.auth.token.get('impersonationSchoolId', '') == schoolId
          && impersonationSessionLive(schoolId);
    }

    function devReadOnly() {
      return request.auth != null
          && request.auth.token.get('devReadOnly', false) == true;
    }

    function writeAllowedForDev() {
      return !devReadOnly();
    }

    // ── Per-school feature gates ────────────────────────────────────
    // Server-side backstop for parent↔teacher messaging (the reading-log
    // comment threads). One get() of the school doc — cached per request and
    // only on the low-volume comment-create path — reads
    // settings.messaging.enabled. Defaults to TRUE for legacy docs without the
    // setting, so messaging fails OPEN: an enabled school is never blocked, and
    // a school that has explicitly turned messaging off can't have comment
    // threads created even by a stale or tampered client.
    function messagingEnabled(schoolId) {
      return get(/databases/$(database)/documents/schools/$(schoolId))
          .data.get('settings', {})
          .get('messaging', {})
          .get('enabled', true);
    }

    match /schools/{schoolId} {
      allow list: if isSignedIn();
      allow get: if belongsToSchool(schoolId) || isDevImpersonatingSchool(schoolId);

      allow create: if isSignedIn() &&
          request.resource.data.createdBy == request.auth.uid &&
          writeAllowedForDev();

      allow update: if isSchoolAdmin(schoolId) && writeAllowedForDev();

      // Controlled counter increments for onboarding/registration lifecycle.
      allow update: if isSignedIn() &&
          writeAllowedForDev() &&
          request.resource.data.diff(resource.data).affectedKeys().size() == 1 &&
          (
            (
              request.resource.data.diff(resource.data).affectedKeys().hasOnly(['teacherCount']) &&
              request.resource.data.teacherCount == resource.data.teacherCount + 1 &&
              (isSchoolAdmin(schoolId) || isTeacher(schoolId))
            ) ||
            (
              request.resource.data.diff(resource.data).affectedKeys().hasOnly(['parentCount']) &&
              request.resource.data.parentCount == resource.data.parentCount + 1 &&
              (isSchoolAdmin(schoolId) || isParentMember(schoolId))
            ) ||
            (
              request.resource.data.diff(resource.data).affectedKeys().hasOnly(['studentCount']) &&
              request.resource.data.studentCount == resource.data.studentCount + 1 &&
              (isSchoolAdmin(schoolId) || isTeacher(schoolId))
            )
          );

      allow delete: if false;

      match /users/{userId} {
        allow get: if (isSignedIn() && request.auth.uid == userId) ||
            isSchoolAdmin(schoolId) ||
            isTeacher(schoolId) ||
            isDevImpersonatingSchool(schoolId);

        allow list: if isSchoolAdmin(schoolId) ||
            isTeacher(schoolId) ||
            isDevImpersonatingSchool(schoolId);

        // Teacher self-create was REMOVED (1.3). The legitimate teacher signup
        // writes this doc SERVER-SIDE via enrollLinkedPhoneAsMfa /
        // finalizeTeacher (Admin SDK, bypasses rules) after validating a school
        // code — no Flutter client SDK path creates a teacher doc. Self-create
        // let any account holder become a teacher of any school (isTeacher()
        // reads exactly this self-authored doc → all children's PII). The only
        // client creates that remain: an existing school admin provisioning
        // staff, and the first-admin bootstrap of a school they created.
        allow create: if isSignedIn() &&
            writeAllowedForDev() &&
            request.resource.data.schoolId == schoolId &&
            (
              isSchoolAdmin(schoolId) ||
              (
                request.auth.uid == userId &&
                request.resource.data.role == 'schoolAdmin' &&
                exists(/databases/$(database)/documents/schools/$(schoolId)) &&
                get(/databases/$(database)/documents/schools/$(schoolId)).data.createdBy == request.auth.uid
              )
            );

        // Self-updates restricted to a small set of user-owned fields.
        // Anything outside this list (rate limits, subscription/entitlement
        // state, role/permissions, MFA verification flags, etc.) must be
        // written exclusively from a trusted source (Admin SDK in Cloud
        // Functions or the super-admin backend), bypassing client rules.
        allow update: if isSignedIn() &&
            writeAllowedForDev() &&
            (
              isSchoolAdmin(schoolId) ||
              (
                request.auth.uid == userId &&
                request.resource.data.role == resource.data.role &&
                request.resource.data.schoolId == resource.data.schoolId &&
                request.resource.data.diff(resource.data).affectedKeys().hasOnly([
                  'preferences',
                  'fcmToken',
                  'fcmTokenUpdatedAt',
                  'lastLoginAt',
                  'relationshipLabel',
                  // Profile mascot a staff member picks for themselves (app/portal).
                  // Category-vs-role (la_/mt_/ft_) is enforced by the write paths.
                  'characterId',
                ])
              )
            );

        allow delete: if isSchoolAdmin(schoolId) && writeAllowedForDev();
      }

      match /parents/{parentId} {
        allow get: if (isSignedIn() && request.auth.uid == parentId) ||
            isSchoolAdmin(schoolId) ||
            isTeacher(schoolId) ||
            isDevImpersonatingSchool(schoolId);

        allow list: if isSchoolAdmin(schoolId) ||
            isTeacher(schoolId) ||
            isDevImpersonatingSchool(schoolId);

        // Parent self-create REMAINS (unlike teacher self-create, removed in
        // 1.3). The phone-primary and email+MFA parent signups now finalise
        // server-side (finalizeParentSignup / enrollLinkedPhoneAsMfa), but the
        // existing-MFA parent who links a child at a NEW school still
        // client-creates their parent membership there. Residual risk is low: a
        // bare parent doc has empty `linkedChildren`, which gates every child
        // PII / allocation read, and parentIds self-append was removed below.
        // Closing this fully needs a server path for cross-school existing-MFA
        // linking (or a pendingParent/{uid} server marker).
        allow create: if isSignedIn() &&
            writeAllowedForDev() &&
            request.resource.data.schoolId == schoolId &&
            (
              isSchoolAdmin(schoolId) ||
              (
                request.auth.uid == parentId &&
                request.resource.data.role == 'parent'
              )
            );

        // Self-updates restricted to a small set of parent-owned fields.
        // Anything outside this list (rate limits, subscription/entitlement
        // state, role, MFA verification flags, linked-children mutations,
        // etc.) must be written exclusively from a trusted source (Admin SDK
        // in Cloud Functions or the super-admin backend).
        allow update: if isSignedIn() &&
            writeAllowedForDev() &&
            (
              isSchoolAdmin(schoolId) ||
              (
                request.auth.uid == parentId &&
                request.resource.data.role == resource.data.role &&
                request.resource.data.schoolId == resource.data.schoolId &&
                request.resource.data.diff(resource.data).affectedKeys().hasOnly([
                  'preferences',
                  'fcmToken',
                  'fcmTokenUpdatedAt',
                  'lastLoginAt',
                  'relationshipLabel',
                ])
              )
            );

        allow delete: if isSchoolAdmin(schoolId) && writeAllowedForDev();

        match /notifications/{notificationId} {
          allow get, list: if (isSignedIn() && request.auth.uid == parentId) ||
              isDevImpersonatingSchool(schoolId);

          allow create: if false;

          // Parents may clear their own inbox (swipe-to-dismiss & Clear all).
          allow delete: if isSignedIn() &&
              writeAllowedForDev() &&
              request.auth.uid == parentId;

          allow update: if isSignedIn() &&
              writeAllowedForDev() &&
              request.auth.uid == parentId &&
              request.resource.data.diff(resource.data).affectedKeys().hasOnly(['isRead', 'readAt']) &&
              request.resource.data.campaignId == resource.data.campaignId &&
              request.resource.data.schoolId == resource.data.schoolId;
        }
      }

      match /students/{studentId} {
        allow get, list: if isSchoolAdmin(schoolId) ||
            isTeacher(schoolId) ||
            isDevImpersonatingSchool(schoolId);

        allow get: if isSignedIn() &&
            getUserData(schoolId).linkedChildren != null &&
            studentId in getUserData(schoolId).linkedChildren;

        allow create: if (isSchoolAdmin(schoolId) || isTeacher(schoolId)) &&
            writeAllowedForDev() &&
            request.resource.data.schoolId == schoolId;

        // Staff may edit student profile / reading-level fields, but NOT the
        // server-owned `access` entitlement map (writing access.status='active'
        // would bypass the licensing gate) nor `parentIds` (owned by the parent
        // linking system / Admin SDK). Those are written only via Cloud
        // Functions (buildStudentAccess, linkParentToStudent), which bypass
        // rules. `access` is set legitimately server-side only.
        // `autoAward` is the weekly Top Reader award — written ONLY by the
        // topReaderAward Cloud Function (Admin SDK); clients must not spoof it.
        // (`manualAward`, the teacher's special award, is intentionally NOT
        // blocked — teachers set it from the app.)
        allow update: if (isSchoolAdmin(schoolId) || isTeacher(schoolId)) &&
            writeAllowedForDev() &&
            !request.resource.data.diff(resource.data).affectedKeys()
                .hasAny(['access', 'parentIds', 'autoAward']);

        allow delete: if (isSchoolAdmin(schoolId) || isTeacher(schoolId)) &&
            writeAllowedForDev();

        // Parent linking writes `parentIds` SERVER-SIDE only, via the
        // linkParentToStudent callable (Admin SDK, TOCTOU-safe code validation
        // — see parent_linking.ts). The old client self-append rule was REMOVED
        // (1.3): no client writes parentIds directly, and self-append (gated
        // only on "caller has a parent doc in the school") let any parent-doc
        // holder pollute an arbitrary student's parentIds without a valid link
        // code.

        // Profile character: a linked parent can set only their child's
        // characterId (the profile mascot they pick in-app).
        allow update: if isSignedIn() &&
            writeAllowedForDev() &&
            getUserData(schoolId).linkedChildren != null &&
            studentId in getUserData(schoolId).linkedChildren &&
            request.resource.data.diff(resource.data).affectedKeys().hasOnly(['characterId']);

        match /readingLevelEvents/{eventId} {
          allow get, list: if isSchoolAdmin(schoolId) ||
              isTeacher(schoolId) ||
              isDevImpersonatingSchool(schoolId);
          allow create: if (isSchoolAdmin(schoolId) || isTeacher(schoolId)) &&
              writeAllowedForDev();
          allow update, delete: if false;
        }
      }

      match /classes/{classId} {
        allow get, list: if isSchoolAdmin(schoolId) || isDevImpersonatingSchool(schoolId);

        allow get, list: if isTeacher(schoolId) &&
            (resource.data.teacherId == request.auth.uid ||
                (resource.data.teacherIds != null &&
                    request.auth.uid in resource.data.teacherIds));

        allow get, list: if isSignedIn() &&
            getUserData(schoolId).linkedChildren != null &&
            resource.data.studentIds.hasAny(getUserData(schoolId).linkedChildren);

        allow create, delete: if isSchoolAdmin(schoolId) && writeAllowedForDev();

        allow update: if writeAllowedForDev() &&
            (
              isSchoolAdmin(schoolId) ||
              (isTeacher(schoolId) &&
                  (resource.data.teacherId == request.auth.uid ||
                      (resource.data.teacherIds != null &&
                          request.auth.uid in resource.data.teacherIds)))
            );
      }

      match /readingLogs/{logId} {
        allow get, list: if isSchoolAdmin(schoolId) ||
            isTeacher(schoolId) ||
            isDevImpersonatingSchool(schoolId);

        allow get, list: if isSignedIn() &&
            getUserData(schoolId).linkedChildren != null &&
            resource.data.studentId in getUserData(schoolId).linkedChildren;

        // The parent logging path is the revenue/usage write and the single
        // enforcement point for entitlement. One get() of the student doc (low
        // volume — once per log) gates it on live access: if the child's access
        // has lapsed (non-renewal) or been suspended (unpaid/off-boarded school
        // — the trigger cascades status to 'suspended'), the write is DENIED.
        // Student READS are intentionally left open so the app can read
        // `access` to render the "access lapsed — contact your school" screen.
        allow create: if isSignedIn() &&
            writeAllowedForDev() &&
            getUserData(schoolId).linkedChildren != null &&
            request.resource.data.studentId in getUserData(schoolId).linkedChildren &&
            request.resource.data.parentId == request.auth.uid &&
            studentAccessLive(
              get(/databases/$(database)/documents/schools/$(schoolId)/students/$(request.resource.data.studentId)).data
            );

        // Teacher proxy logs: a teacher logs reading on behalf of a student
        // whose carer can't use the app. `parentId` holds the teacher's UID
        // (creator) so the existing ownership clauses in update/delete keep
        // working. `loggedByRole == 'teacher'` is the explicit proxy signal
        // and stops a teacher accidentally writing a parent-shaped log.
        // Membership is verified against the class document's teacher
        // assignment (see teacherTeachesClass) — the denormalised
        // `classIds` on the teacher's user doc is created empty and never
        // synced by the portal, so relying on it denied every proxy log.
        allow create: if isSignedIn() &&
            writeAllowedForDev() &&
            isTeacher(schoolId) &&
            request.resource.data.parentId == request.auth.uid &&
            request.resource.data.loggedByRole == 'teacher' &&
            teacherTeachesClass(schoolId, request.resource.data.classId);

        allow update: if writeAllowedForDev() &&
            (
              (isSignedIn() && resource.data.parentId == request.auth.uid) ||
              isSchoolAdmin(schoolId) ||
              isTeacher(schoolId)
            );

        // A linked parent who didn't create the log (a co-carer, or someone
        // viewing a teacher-proxy log for their child) may still clear their
        // own unread badge. Scoped tightly: the only field they can touch is
        // `commentsViewedAt`, and within it only their own uid key — so a
        // non-owner can't edit log content or another carer's read marker.
        allow update: if writeAllowedForDev() &&
            isSignedIn() &&
            getUserData(schoolId).linkedChildren != null &&
            resource.data.studentId in getUserData(schoolId).linkedChildren &&
            request.resource.data.diff(resource.data)
                .affectedKeys().hasOnly(['commentsViewedAt']) &&
            request.resource.data.commentsViewedAt
                .diff(resource.data.get('commentsViewedAt', {}))
                .affectedKeys().hasOnly([request.auth.uid]);

        // Parent can delete a log they created (powers the widget-undo
        // banner). Stats are reconciled by the aggregateStudentStats Cloud
        // Function on log delete, so no client-side stats write is needed.
        allow delete: if writeAllowedForDev() &&
            (
              isSchoolAdmin(schoolId) ||
              (isSignedIn() && resource.data.parentId == request.auth.uid)
            );

        // Threaded comments. `studentId` is denormalized onto each comment so
        // these rules mirror the parent/teacher access on the parent log
        // without an extra get() to read it.
        match /comments/{commentId} {
          allow get, list: if isSchoolAdmin(schoolId) ||
              isTeacher(schoolId) ||
              isDevImpersonatingSchool(schoolId);

          allow get, list: if isSignedIn() &&
              getUserData(schoolId).linkedChildren != null &&
              resource.data.studentId in getUserData(schoolId).linkedChildren;

          // Teachers post as staff; parents post on their own child's log.
          // authorId is pinned to the caller so attribution can't be spoofed.
          // messagingEnabled() is the server-side backstop to the app-side gate:
          // a school that has turned parent↔teacher messaging off can't have new
          // threads created regardless of client state.
          allow create: if writeAllowedForDev() &&
              messagingEnabled(schoolId) &&
              request.resource.data.authorId == request.auth.uid &&
              (
                (isTeacher(schoolId) &&
                    request.resource.data.authorRole == 'teacher') ||
                (isSignedIn() &&
                    request.resource.data.authorRole == 'parent' &&
                    getUserData(schoolId).linkedChildren != null &&
                    request.resource.data.studentId in
                        getUserData(schoolId).linkedChildren)
              );

          // Comments are immutable; edits/deletes are denied (default).
        }
      }

      match /allocations/{allocationId} {
        allow get, list: if isSchoolAdmin(schoolId) ||
            isTeacher(schoolId) ||
            parentCanReadAllocation(schoolId, resource.data) ||
            isDevImpersonatingSchool(schoolId);
        allow create, update, delete: if (isSchoolAdmin(schoolId) || isTeacher(schoolId)) &&
            writeAllowedForDev();
      }

      match /books/{bookId} {
        // Any school member can read school-scoped book metadata.
        allow get, list: if belongsToSchool(schoolId) || isDevImpersonatingSchool(schoolId);

        // Only teachers and admins can add/update books (parents cannot write)
        allow create, update: if (isSchoolAdmin(schoolId) || isTeacher(schoolId)) &&
            writeAllowedForDev() &&
            request.resource.data.schoolId == schoolId;

        allow delete: if isSchoolAdmin(schoolId) && writeAllowedForDev();
      }

      match /readingGroups/{groupId} {
        allow get, list: if belongsToSchool(schoolId) || isDevImpersonatingSchool(schoolId);
        allow create: if (isTeacher(schoolId) || isSchoolAdmin(schoolId)) && writeAllowedForDev();
        allow update: if (isTeacher(schoolId) || isSchoolAdmin(schoolId)) && writeAllowedForDev();
        allow delete: if (isTeacher(schoolId) || isSchoolAdmin(schoolId)) && writeAllowedForDev();
      }

      match /notificationCampaigns/{campaignId} {
        allow get, list: if isSchoolAdmin(schoolId) ||
            (isTeacher(schoolId) && resource.data.createdBy == request.auth.uid) ||
            isDevImpersonatingSchool(schoolId);

        allow create, update, delete: if false;
      }

      match /parentOnboardingEmails/{emailId} {
        allow get, list: if isSchoolAdmin(schoolId) || isDevImpersonatingSchool(schoolId);
        allow create: if isSchoolAdmin(schoolId)
            && writeAllowedForDev()
            && request.resource.data.status == 'queued'
            && request.resource.data.schoolId == schoolId;
        allow update, delete: if false;
      }

      match /staffOnboardingEmails/{emailId} {
        allow get, list: if isSchoolAdmin(schoolId) || isDevImpersonatingSchool(schoolId);
        allow create: if isSchoolAdmin(schoolId)
            && writeAllowedForDev()
            && request.resource.data.status == 'queued'
            && request.resource.data.schoolId == schoolId;
        allow update, delete: if false;
      }

      // Plaintext temporary passwords for admin-imported staff. Admin-SDK
      // only (the credentials API and the email Cloud Function) — never
      // readable by any client, including the staff member themselves.
      match /staffCredentials/{userId} {
        allow read, write: if false;
      }
    }

    // ── Community Book Database (global, cross-school) ──────────────
    // Shared catalog that any teacher/admin can contribute to.
    // No client-side delete — only Admin SDK from the super-admin backend.
    match /community_books/{isbn} {
      // Any authenticated user can read community books.
      allow get, list: if isSignedIn();

      // Only teachers and school admins can create new entries.
      // The contributor must declare their schoolId so the role check can verify.
      allow create: if isSignedIn()
          && writeAllowedForDev()
          && request.resource.data.contributedBySchoolId is string
          && request.resource.data.contributedBySchoolId.size() > 0
          && (isTeacher(request.resource.data.contributedBySchoolId)
              || isSchoolAdmin(request.resource.data.contributedBySchoolId))
          && request.resource.data.contributedBy == request.auth.uid;

      // Teachers/admins can update (improve metadata, add cover).
      // The original contributedBy field is immutable.
      allow update: if isSignedIn()
          && writeAllowedForDev()
          && request.resource.data.contributedBy == resource.data.contributedBy
          && request.resource.data.contributedBySchoolId is string
          && (isTeacher(request.resource.data.contributedBySchoolId)
              || isSchoolAdmin(request.resource.data.contributedBySchoolId));

      // No client-side delete.
      allow delete: if false;

      // Future: deletion request subcollection.
      match /deletionRequests/{requestId} {
        allow create: if isSignedIn()
            && writeAllowedForDev()
            && request.resource.data.requestedBy == request.auth.uid
            && request.resource.data.schoolId is string
            && (isTeacher(request.resource.data.schoolId)
                || isSchoolAdmin(request.resource.data.schoolId));

        // Only readable/manageable via Admin SDK.
        allow get, list, update, delete: if false;
      }
    }

    // Legacy top-level books collection (read-only migration fallback).
    match /books/{bookId} {
      allow get, list: if isSignedIn() &&
          resource.data.schoolId != null &&
          belongsToSchool(resource.data.schoolId);

      allow create, update, delete: if false;
    }

    match /users/{userId} {
      allow get: if isSignedIn() && request.auth.uid == userId;
      allow create, update, delete: if isSignedIn() &&
          request.auth.uid == userId &&
          writeAllowedForDev();
    }

    match /schoolOnboarding/{onboardingId} {
      // Demo-request create is intentionally reachable by an ANONYMOUS visitor
      // (the public "request a demo" form runs before any account exists), so
      // we can't require isSignedIn() here. Instead validate the shape: it must
      // look like a genuine demo request and must NOT pre-claim an admin owner
      // (adminUserId is set later, only by the authenticated ownership-claim
      // update below). This stops anonymous callers writing arbitrary docs.
      allow create: if writeAllowedForDev() &&
          request.resource.data.schoolName is string &&
          request.resource.data.schoolName.size() > 0 &&
          request.resource.data.contactEmail is string &&
          request.resource.data.contactEmail.size() > 0 &&
          request.resource.data.status == 'demo' &&
          request.resource.data.createdAt is timestamp &&
          request.resource.data.get('adminUserId', null) == null;

      allow get, list: if isSignedIn() &&
          (
            resource.data.contactEmail == request.auth.token.email ||
            resource.data.adminUserId == request.auth.uid
          );

      allow update: if isSignedIn() &&
          writeAllowedForDev() &&
          (
            resource.data.contactEmail == request.auth.token.email ||
            resource.data.adminUserId == request.auth.uid ||
            (resource.data.adminUserId == null &&
                request.resource.data.adminUserId == request.auth.uid)
          );

      allow delete: if false;
    }

    match /studentLinkCodes/{codeId} {
      // Verification is server-side only: the verifyStudentLinkCode /
      // linkParentToStudent / createCoParentInvite callables (Admin SDK) look
      // codes up by exact value. There is deliberately NO unauthenticated
      // `list` rule — a bounded unauthenticated list let anyone paginate and
      // harvest every child-link code.

      allow get: if isSignedIn() &&
          (
            isSchoolAdmin(resource.data.schoolId) ||
            isTeacher(resource.data.schoolId) ||
            resource.data.usedBy == request.auth.uid
          );

      allow list: if isSignedIn() &&
          (
            isSchoolAdmin(resource.data.schoolId) ||
            isTeacher(resource.data.schoolId) ||
            resource.data.usedBy == request.auth.uid
          );

      // Co-parent invites are created by the createCoParentInvite callable
      // (Admin SDK), which verifies the caller is a parent linked to the
      // student — so parents no longer create link codes from the client.
      // Only staff may create a code directly.
      allow create: if isSignedIn() &&
          writeAllowedForDev() &&
          request.resource.data.createdBy == request.auth.uid &&
          (
            isSchoolAdmin(request.resource.data.schoolId) ||
            isTeacher(request.resource.data.schoolId)
          );

      allow update: if isSignedIn() &&
          writeAllowedForDev() &&
          (
            (
              isSchoolAdmin(resource.data.schoolId) ||
              isTeacher(resource.data.schoolId)
            ) ||
            (
              request.auth.uid == request.resource.data.usedBy &&
              resource.data.status == 'active' &&
              request.resource.data.status == 'used' &&
              request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'usedBy', 'usedAt'])
            ) ||
            (
              // A guardian cancelling their own pending co-parent invite.
              resource.data.createdBy == request.auth.uid &&
              resource.data.intendedFor == 'co_parent_invite' &&
              resource.data.status == 'active' &&
              request.resource.data.status == 'revoked' &&
              request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'revokedBy', 'revokedAt', 'revokeReason'])
            )
          );

      allow delete: if isSignedIn() && isSchoolAdmin(resource.data.schoolId) && writeAllowedForDev();
    }

    match /notifications/{notificationId} {
      allow read, write: if false;
    }

    match /schoolCodes/{codeId} {
      // Teacher registration validation is server-side only: the
      // verifySchoolCode callable (Admin SDK) looks a code up by exact value.
      // There is deliberately NO unauthenticated `list` rule — a bounded
      // unauthenticated list let anyone paginate and harvest every active
      // school join code (feeding self-provision-as-teacher).

      allow get: if isSignedIn() &&
          (
            isSchoolAdmin(resource.data.schoolId) ||
            isTeacher(resource.data.schoolId)
          );

      allow list: if isSignedIn() &&
          (
            isSchoolAdmin(resource.data.schoolId) ||
            isTeacher(resource.data.schoolId)
          );

      allow create: if isSignedIn() &&
          writeAllowedForDev() &&
          request.resource.data.createdBy == request.auth.uid &&
          isSchoolAdmin(request.resource.data.schoolId);

      allow update: if isSignedIn() &&
          writeAllowedForDev() &&
          isSchoolAdmin(resource.data.schoolId) &&
          request.resource.data.schoolId == resource.data.schoolId;

      // Teacher registration increments usage count by exactly 1.
      allow update: if isSignedIn() &&
          writeAllowedForDev() &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['usageCount']) &&
          request.resource.data.usageCount == resource.data.usageCount + 1 &&
          (isSchoolAdmin(resource.data.schoolId) || isTeacher(resource.data.schoolId));

      allow delete: if isSignedIn() && isSchoolAdmin(resource.data.schoolId) && writeAllowedForDev();
    }

    // ── User Feedback ──────────────────────────────────────────────
    match /feedback/{feedbackId} {
      // Any signed-in user can submit feedback.
      allow create: if isSignedIn() &&
          writeAllowedForDev() &&
          request.resource.data.userId == request.auth.uid;

      // Read/update/delete only via Admin SDK (super-admin dashboard).
      allow get, list, update, delete: if false;
    }

    // pendingUserDeletions is written/read exclusively via Admin SDK (Cloud Function).
    // No client access permitted.
    match /pendingUserDeletions/{userId} {
      allow read, write: if false;
    }

    match /userSchoolIndex/{emailHash} {
      allow get: if isSignedIn() && resource.data.userId == request.auth.uid;

      allow create: if isSignedIn() &&
          writeAllowedForDev() &&
          request.resource.data.userId == request.auth.uid;

      allow update: if isSignedIn() &&
          writeAllowedForDev() &&
          resource.data.userId == request.auth.uid &&
          request.resource.data.userId == request.auth.uid;

      allow delete: if isSignedIn() &&
          writeAllowedForDev() &&
          resource.data.userId == request.auth.uid;

      allow list: if false;
    }

    // Dev-access allowlist. Doc ID is sha256(lowercased email). Clients
    // (Flutter, school-admin-web) can only `get` a specific doc by hash —
    // typically the hash of their own email — which lets them self-check
    // without exposing who else is on the list. Listing is denied.
    // Writes go exclusively through the super-admin portal (Admin SDK).
    match /devAccessEmails/{emailHash} {
      allow get: if isSignedIn();
      allow list, create, update, delete: if false;
    }

    // ── Platform-wide feature flags ─────────────────────────────────
    // Written exclusively by the super-admin portal via the Admin SDK
    // (e.g. the comprehension-recording kill switch at
    // platformConfig/comprehensionRecording). Signed-in clients may
    // `get` individual flags to compute effective feature state; a
    // missing doc means the feature is enabled. Listing is denied.
    match /platformConfig/{flagId} {
      allow get: if isSignedIn();
      allow list, create, update, delete: if false;
    }

    // ── Super-admin allowlist ───────────────────────────────────────
    // Doc ID is the Firebase UID. Presence of a doc grants super-admin
    // power (revoke impersonation sessions, export audit logs). No
    // self-reads; only the Admin SDK inside Cloud Functions consults
    // this. Seeded manually via the Firebase console.
    match /superAdmins/{uid} {
      allow read, write: if false;
    }

    // ── Developer impersonation sessions ────────────────────────────
    // Lifecycle (create, status transitions) is owned by Cloud Functions
    // via the Admin SDK. Dev clients may `get` their own active session
    // so they can react when a super-admin revokes it.
    match /devImpersonationSessions/{sessionId} {
      allow get: if isSignedIn() && resource.data.devUid == request.auth.uid;
      allow list, create, update, delete: if false;
    }

    // ── Developer impersonation audit trail (append-only) ───────────
    // Entirely closed to clients. Only Cloud Functions write (via
    // Admin SDK) and only lumi-admin reads (via Admin SDK in server
    // routes). This keeps the log tamper-resistant.
    match /devImpersonationAudit/{eventId} {
      allow read, write: if false;
    }

    // ── Developer impersonation rate-limit counters ─────────────────
    // Per-developer counters for session-start throttling. Cloud
    // Functions only.
    match /devImpersonationRateLimits/{devUid} {
      allow read, write: if false;
    }
  }
}
