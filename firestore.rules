rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function getUserData(schoolId) {
      let userPath = /databases/$(database)/documents/schools/$(schoolId)/users/$(request.auth.uid);
      let parentPath = /databases/$(database)/documents/schools/$(schoolId)/parents/$(request.auth.uid);

      return exists(userPath)
          ? get(userPath).data
          : exists(parentPath)
              ? get(parentPath).data
              : null;
    }

    function userRole(schoolId) {
      let userData = getUserData(schoolId);
      return userData == null ? null : userData.role;
    }

    function isSchoolAdmin(schoolId) {
      return isSignedIn() && userRole(schoolId) == 'schoolAdmin';
    }

    function isTeacher(schoolId) {
      return isSignedIn() && userRole(schoolId) == 'teacher';
    }

    function isParentMember(schoolId) {
      return isSignedIn() && userRole(schoolId) == 'parent';
    }

    function belongsToSchool(schoolId) {
      return isSignedIn() &&
          (exists(/databases/$(database)/documents/schools/$(schoolId)/users/$(request.auth.uid)) ||
              exists(/databases/$(database)/documents/schools/$(schoolId)/parents/$(request.auth.uid)));
    }

    match /schools/{schoolId} {
      allow list: if isSignedIn();
      allow get: if belongsToSchool(schoolId);

      allow create: if isSignedIn() &&
          request.resource.data.createdBy == request.auth.uid;

      allow update: if isSchoolAdmin(schoolId);

      // Controlled counter increments for onboarding/registration lifecycle.
      allow update: if isSignedIn() &&
          request.resource.data.diff(resource.data).affectedKeys().size() == 1 &&
          (
            (
              request.resource.data.diff(resource.data).affectedKeys().hasOnly(['teacherCount']) &&
              request.resource.data.teacherCount == resource.data.teacherCount + 1 &&
              (isSchoolAdmin(schoolId) || isTeacher(schoolId))
            ) ||
            (
              request.resource.data.diff(resource.data).affectedKeys().hasOnly(['parentCount']) &&
              request.resource.data.parentCount == resource.data.parentCount + 1 &&
              (isSchoolAdmin(schoolId) || isParentMember(schoolId))
            ) ||
            (
              request.resource.data.diff(resource.data).affectedKeys().hasOnly(['studentCount']) &&
              request.resource.data.studentCount == resource.data.studentCount + 1 &&
              (isSchoolAdmin(schoolId) || isTeacher(schoolId))
            )
          );

      allow delete: if false;

      match /users/{userId} {
        allow get: if (isSignedIn() && request.auth.uid == userId) ||
            isSchoolAdmin(schoolId) ||
            isTeacher(schoolId);

        allow list: if isSchoolAdmin(schoolId) || isTeacher(schoolId);

        // Non-admins can only create their own user doc.
        allow create: if isSignedIn() &&
            request.resource.data.schoolId == schoolId &&
            (
              isSchoolAdmin(schoolId) ||
              (
                request.auth.uid == userId &&
                (
                  request.resource.data.role == 'teacher' ||
                  (
                    request.resource.data.role == 'schoolAdmin' &&
                    exists(/databases/$(database)/documents/schools/$(schoolId)) &&
                    get(/databases/$(database)/documents/schools/$(schoolId)).data.createdBy == request.auth.uid
                  )
                )
              )
            );

        allow update: if isSignedIn() &&
            (
              isSchoolAdmin(schoolId) ||
              (
                request.auth.uid == userId &&
                request.resource.data.role == resource.data.role &&
                request.resource.data.schoolId == resource.data.schoolId
              )
            );

        allow delete: if isSchoolAdmin(schoolId);
      }

      match /parents/{parentId} {
        allow get: if (isSignedIn() && request.auth.uid == parentId) ||
            isSchoolAdmin(schoolId) ||
            isTeacher(schoolId);

        allow list: if isSchoolAdmin(schoolId) || isTeacher(schoolId);

        // Non-admins can only create their own parent doc.
        allow create: if isSignedIn() &&
            request.resource.data.schoolId == schoolId &&
            (
              isSchoolAdmin(schoolId) ||
              (
                request.auth.uid == parentId &&
                request.resource.data.role == 'parent'
              )
            );

        allow update: if isSignedIn() &&
            (
              isSchoolAdmin(schoolId) ||
              (
                request.auth.uid == parentId &&
                request.resource.data.role == resource.data.role &&
                request.resource.data.schoolId == resource.data.schoolId
              )
            );

        allow delete: if isSchoolAdmin(schoolId);
      }

      match /students/{studentId} {
        allow get, list: if isSchoolAdmin(schoolId) || isTeacher(schoolId);

        allow get: if isSignedIn() &&
            getUserData(schoolId).linkedChildren != null &&
            studentId in getUserData(schoolId).linkedChildren;

        allow create: if (isSchoolAdmin(schoolId) || isTeacher(schoolId)) &&
            request.resource.data.schoolId == schoolId;

        allow update, delete: if isSchoolAdmin(schoolId) || isTeacher(schoolId);

        // Parent linking: parent can only append their own UID to parentIds.
        allow update: if isSignedIn() &&
            exists(/databases/$(database)/documents/schools/$(schoolId)/parents/$(request.auth.uid)) &&
            request.resource.data.diff(resource.data).affectedKeys().hasOnly(['parentIds']) &&
            request.resource.data.parentIds.hasAll(resource.data.parentIds) &&
            request.auth.uid in request.resource.data.parentIds;
      }

      match /classes/{classId} {
        allow get, list: if isSchoolAdmin(schoolId);

        allow get, list: if isTeacher(schoolId) &&
            (resource.data.teacherId == request.auth.uid ||
                (resource.data.teacherIds != null &&
                    request.auth.uid in resource.data.teacherIds));

        allow get, list: if isSignedIn() &&
            getUserData(schoolId).linkedChildren != null &&
            resource.data.studentIds.hasAny(getUserData(schoolId).linkedChildren);

        allow create, delete: if isSchoolAdmin(schoolId);

        allow update: if isSchoolAdmin(schoolId) ||
            (isTeacher(schoolId) &&
                (resource.data.teacherId == request.auth.uid ||
                    (resource.data.teacherIds != null &&
                        request.auth.uid in resource.data.teacherIds)));
      }

      match /readingLogs/{logId} {
        allow get, list: if isSchoolAdmin(schoolId) || isTeacher(schoolId);

        allow get, list: if isSignedIn() &&
            getUserData(schoolId).linkedChildren != null &&
            resource.data.studentId in getUserData(schoolId).linkedChildren;

        allow create: if isSignedIn() &&
            getUserData(schoolId).linkedChildren != null &&
            request.resource.data.studentId in getUserData(schoolId).linkedChildren &&
            request.resource.data.parentId == request.auth.uid;

        allow update: if (isSignedIn() && resource.data.parentId == request.auth.uid) ||
            isSchoolAdmin(schoolId) ||
            isTeacher(schoolId);

        allow delete: if isSchoolAdmin(schoolId);
      }

      match /allocations/{allocationId} {
        allow get, list: if belongsToSchool(schoolId);
        allow create, update, delete: if isSchoolAdmin(schoolId) || isTeacher(schoolId);
      }
    }

    match /users/{userId} {
      allow get, create, update, delete: if isSignedIn() && request.auth.uid == userId;
    }

    match /schoolOnboarding/{onboardingId} {
      allow create: if true;

      allow get, list: if isSignedIn() &&
          (
            resource.data.contactEmail == request.auth.token.email ||
            resource.data.adminUserId == request.auth.uid
          );

      allow update: if isSignedIn() &&
          (
            resource.data.contactEmail == request.auth.token.email ||
            resource.data.adminUserId == request.auth.uid ||
            (resource.data.adminUserId == null &&
                request.resource.data.adminUserId == request.auth.uid)
          );

      allow delete: if false;
    }

    match /studentLinkCodes/{codeId} {
      // Parent verification path (unauthenticated): small bounded query only.
      allow list: if !isSignedIn() &&
          request.query.limit != null &&
          request.query.limit > 0 &&
          request.query.limit <= 10;

      allow get: if isSignedIn() &&
          (
            isSchoolAdmin(resource.data.schoolId) ||
            isTeacher(resource.data.schoolId) ||
            resource.data.usedBy == request.auth.uid
          );

      allow list: if isSignedIn() &&
          (
            isSchoolAdmin(resource.data.schoolId) ||
            isTeacher(resource.data.schoolId) ||
            resource.data.usedBy == request.auth.uid
          );

      allow create: if isSignedIn() &&
          request.resource.data.createdBy == request.auth.uid &&
          (isSchoolAdmin(request.resource.data.schoolId) ||
              isTeacher(request.resource.data.schoolId));

      allow update: if isSignedIn() &&
          (
            (
              isSchoolAdmin(resource.data.schoolId) ||
              isTeacher(resource.data.schoolId)
            ) ||
            (
              request.auth.uid == request.resource.data.usedBy &&
              resource.data.status == 'active' &&
              request.resource.data.status == 'used' &&
              request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'usedBy', 'usedAt'])
            )
          );

      allow delete: if isSignedIn() && isSchoolAdmin(resource.data.schoolId);
    }

    match /notifications/{notificationId} {
      allow get, list: if isSignedIn() &&
          (
            resource.data.userId == request.auth.uid ||
            resource.data.parentUserId == request.auth.uid
          );

      allow create: if isSignedIn() &&
          request.resource.data.schoolId != null &&
          belongsToSchool(request.resource.data.schoolId);

      allow update: if isSignedIn() &&
          (
            resource.data.userId == request.auth.uid ||
            resource.data.parentUserId == request.auth.uid
          );

      allow delete: if isSignedIn() &&
          resource.data.schoolId != null &&
          isSchoolAdmin(resource.data.schoolId);
    }

    match /schoolCodes/{codeId} {
      // Teacher registration validation path: bounded, unauthenticated query.
      allow list: if !isSignedIn() && request.query.limit == 1;

      allow get: if isSignedIn() &&
          (
            isSchoolAdmin(resource.data.schoolId) ||
            isTeacher(resource.data.schoolId)
          );

      allow list: if isSignedIn() &&
          (
            isSchoolAdmin(resource.data.schoolId) ||
            isTeacher(resource.data.schoolId)
          );

      allow create: if isSignedIn() &&
          request.resource.data.createdBy == request.auth.uid &&
          isSchoolAdmin(request.resource.data.schoolId);

      allow update: if isSignedIn() &&
          isSchoolAdmin(resource.data.schoolId) &&
          request.resource.data.schoolId == resource.data.schoolId;

      // Teacher registration increments usage count by exactly 1.
      allow update: if isSignedIn() &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['usageCount']) &&
          request.resource.data.usageCount == resource.data.usageCount + 1 &&
          (isSchoolAdmin(resource.data.schoolId) || isTeacher(resource.data.schoolId));

      allow delete: if isSignedIn() && isSchoolAdmin(resource.data.schoolId);
    }

    match /userSchoolIndex/{emailHash} {
      allow get: if isSignedIn() && resource.data.userId == request.auth.uid;

      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;

      allow update: if isSignedIn() &&
          resource.data.userId == request.auth.uid &&
          request.resource.data.userId == request.auth.uid;

      allow delete: if isSignedIn() && resource.data.userId == request.auth.uid;

      allow list: if false;
    }
  }
}
