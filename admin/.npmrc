# Firebase's web-frameworks adapter packages the SSR Cloud Function with `npm`,
# whose strict peer resolution rejects @tremor/react's React 18 peer against the
# app's React 19. pnpm (the workspace's package manager) is lenient here, so this
# npm-only setting only affects that packaging step. Without it the deploy fails
# with ERESOLVE. (@lumi/* workspace deps are in devDependencies so npm never sees
# the `workspace:` protocol.)
legacy-peer-deps=true
