{
  "storage": {
    "rules": "storage.rules"
  },
  "firestore": {
    "rules": "firestore.rules",
    "indexes": "firestore.indexes.json"
  },
  "functions": {
    "source": "functions",
    "predeploy": [
      "npm --prefix \"$RESOURCE_DIR\" run lint",
      "npm --prefix \"$RESOURCE_DIR\" run build"
    ]
  },
  "hosting": [
    {
      "target": "default",
      "public": "build/web",
      "appAssociation": "NONE",
      "ignore": [
        "firebase.json",
        "**/.*",
        "**/node_modules/**"
      ],
      "rewrites": [
        {
          "source": "/.well-known/apple-app-site-association",
          "destination": "/aasa.json"
        },
        {
          "source": "/.well-known/assetlinks.json",
          "destination": "/assetlinks.json"
        },
        {
          "source": "**",
          "destination": "/index.html"
        }
      ]
    },
    {
      "target": "admin",
      "source": "admin",
      "frameworksBackend": {
        "region": "australia-southeast1",
        "memory": "512MiB",
        "maxInstances": 10,
        "serviceAccount": "lumi-super-admin-runtime@lumi-ninc-au.iam.gserviceaccount.com",
        "secrets": [
          "ADMIN_SESSION_SECRET_AU"
        ]
      }
    },
    {
      "target": "school",
      "source": "school-admin-web",
      "frameworksBackend": {
        "region": "australia-southeast1",
        "memory": "512MiB",
        "maxInstances": 10,
        "serviceAccount": "lumi-school-portal-runtime@lumi-ninc-au.iam.gserviceaccount.com"
      }
    },
    {
      "target": "marketing",
      "public": "marketing-site/out",
      "cleanUrls": true,
      "ignore": [
        "firebase.json",
        "**/.*",
        "**/node_modules/**"
      ]
    }
  ],
  "flutter": {
    "platforms": {
      "android": {
        "default": {
          "projectId": "lumi-ninc-au",
          "appId": "1:3795320704:android:47b629e400e8419c37cb65",
          "fileOutput": "android/app/google-services.json"
        },
        "buildConfigurations": {
          ".": {
            "projectId": "lumi-ninc-au",
            "appId": "1:3795320704:android:47b629e400e8419c37cb65",
            "fileOutput": "android/app/google-services.json"
          }
        }
      },
      "ios": {
        "default": {
          "projectId": "lumi-ninc-au",
          "appId": "1:3795320704:ios:4067b645d940238137cb65",
          "uploadDebugSymbols": true,
          "fileOutput": "ios/Runner/GoogleService-Info.plist"
        }
      },
      "dart": {
        "lib/firebase_options.dart": {
          "projectId": "lumi-ninc-au",
          "configurations": {
            "android": "1:3795320704:android:47b629e400e8419c37cb65",
            "ios": "1:3795320704:ios:4067b645d940238137cb65",
            "web": "1:3795320704:web:729cb32dab543bd637cb65"
          }
        }
      }
    }
  }
}
