{
  "storage": {
    "rules": "storage.rules",
    "predeploy": [
      "./scripts/check-storage-rules.sh"
    ]
  },
  "firestore": {
    "rules": "firestore.rules",
    "indexes": "firestore.indexes.json"
  },
  "functions": {
    "source": "functions",
    "predeploy": [
      "npm --prefix \"$RESOURCE_DIR\" run lint",
      "npm --prefix \"$RESOURCE_DIR\" run build"
    ]
  },
  "hosting": [
    {
      "target": "admin",
      "source": "admin",
      "predeploy": [
        "./scripts/check-csv-exports.sh"
      ],
      "frameworksBackend": {
        "region": "australia-southeast1",
        "memory": "512MiB",
        "maxInstances": 10,
        "serviceAccount": "lumi-super-admin-runtime@lumi-ninc-au.iam.gserviceaccount.com",
        "secrets": [
          "ADMIN_SESSION_SECRET_AU",
          "ADMIN_MFA_ENC_KEY_AU"
        ]
      }
    },
    {
      "target": "school",
      "source": "school-admin-web",
      "predeploy": [
        "./scripts/check-csv-exports.sh"
      ],
      "frameworksBackend": {
        "region": "australia-southeast1",
        "memory": "512MiB",
        "maxInstances": 10,
        "serviceAccount": "lumi-school-portal-runtime@lumi-ninc-au.iam.gserviceaccount.com"
      }
    },
    {
      "target": "marketing",
      "public": "marketing-site/out",
      "appAssociation": "NONE",
      "cleanUrls": true,
      "headers": [
        {
          "source": "**",
          "headers": [
            { "key": "X-Content-Type-Options", "value": "nosniff" },
            { "key": "X-Frame-Options", "value": "SAMEORIGIN" },
            { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" }
          ]
        }
      ],
      "ignore": [
        "firebase.json",
        "**/.*",
        "**/node_modules/**"
      ],
      "redirects": [
        {
          "source": "/privacy",
          "destination": "/legal/privacy",
          "type": 301
        },
        {
          "source": "/terms",
          "destination": "/legal/terms",
          "type": 301
        },
        {
          "source": "/legal",
          "destination": "/legal/privacy",
          "type": 301
        }
      ],
      "rewrites": [
        {
          "source": "/.well-known/apple-app-site-association",
          "destination": "/aasa.json"
        },
        {
          "source": "/.well-known/assetlinks.json",
          "destination": "/assetlinks.json"
        }
      ],
      "headers": [
        {
          "source": "/.well-known/apple-app-site-association",
          "headers": [
            {
              "key": "Content-Type",
              "value": "application/json"
            },
            {
              "key": "Cache-Control",
              "value": "public, max-age=3600"
            }
          ]
        },
        {
          "source": "/.well-known/assetlinks.json",
          "headers": [
            {
              "key": "Content-Type",
              "value": "application/json"
            },
            {
              "key": "Cache-Control",
              "value": "public, max-age=3600"
            }
          ]
        }
      ]
    }
  ],
  "flutter": {
    "platforms": {
      "android": {
        "default": {
          "projectId": "lumi-ninc-au",
          "appId": "1:3795320704:android:47b629e400e8419c37cb65",
          "fileOutput": "android/app/google-services.json"
        },
        "buildConfigurations": {
          ".": {
            "projectId": "lumi-ninc-au",
            "appId": "1:3795320704:android:47b629e400e8419c37cb65",
            "fileOutput": "android/app/google-services.json"
          }
        }
      },
      "ios": {
        "default": {
          "projectId": "lumi-ninc-au",
          "appId": "1:3795320704:ios:4067b645d940238137cb65",
          "uploadDebugSymbols": true,
          "fileOutput": "ios/Runner/GoogleService-Info.plist"
        }
      },
      "dart": {
        "lib/firebase_options.dart": {
          "projectId": "lumi-ninc-au",
          "configurations": {
            "android": "1:3795320704:android:47b629e400e8419c37cb65",
            "ios": "1:3795320704:ios:4067b645d940238137cb65",
            "web": "1:3795320704:web:729cb32dab543bd637cb65"
          }
        }
      }
    }
  }
}