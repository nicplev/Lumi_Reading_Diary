<?xml version="1.0" encoding="utf-8"?>
<!-- Adaptive launcher icon (API 26+): solid Lumi-red background sampled from
     the artwork (#EB4544) + the face foreground inset to the safe zone, so
     circle/squircle/rounded-square masks all render cleanly. Legacy
     ic_launcher.png in each mipmap dir covers older launchers. -->
<adaptive-icon xmlns:android="http://schemas.android.com/apk/res/android">
    <background android:drawable="@color/ic_launcher_background"/>
    <foreground android:drawable="@mipmap/ic_launcher_foreground"/>
</adaptive-icon>
