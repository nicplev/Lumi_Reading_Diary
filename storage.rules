rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    function isStaffAtSchool(schoolId) {
      let staff = firestore.get(
        /databases/(default)/documents/schools/$(schoolId)/users/$(request.auth.uid)
      );
      return request.auth != null &&
          (staff.data.role == 'teacher' || staff.data.role == 'schoolAdmin');
    }

    function comprehensionRecordingEnabled() {
      let config = firestore.get(
        /databases/(default)/documents/platformConfig/comprehensionRecording
      );
      return config.data.enabled == true;
    }

    function ownsAudioLog(schoolId, fileName) {
      let logId = request.resource.metadata.logId;
      let log = firestore.get(
        /databases/(default)/documents/schools/$(schoolId)/readingLogs/$(logId)
      );
      return request.auth != null &&
          request.resource.metadata.schoolId == schoolId &&
          request.resource.metadata.ownerUid == request.auth.uid &&
          logId is string &&
          fileName == logId + '.m4a' &&
          log.data.schoolId == schoolId &&
          log.data.parentId == request.auth.uid &&
          log.data.get('loggedByRole', 'parent') != 'teacher';
    }

    // Community book covers: any authenticated user can read.
    // Teachers and admins can upload (create-only, no overwrite).
    // Nobody can delete from client SDK — only Admin SDK from backend.
    match /community_books/covers/{fileName} {
      allow read: if request.auth != null;

      // Only a verified teacher/admin may create a cover. Client overwrites are
      // denied; replacing a shared catalog asset must go through an audited
      // backend path rather than last-writer-wins Storage access.
      allow write: if request.resource != null
                   && resource == null
                   && request.auth != null
                   && request.resource.metadata.schoolId is string
                   && request.resource.metadata.uploaderUid == request.auth.uid
                   && isStaffAtSchool(request.resource.metadata.schoolId)
                   && request.resource.size < 2 * 1024 * 1024
                   && request.resource.contentType == 'image/jpeg';
    }

    // Comprehension voice recordings: short m4a clips recorded by children
    // at the end of the parent's reading-log wizard, played back by
    // teachers on the student detail screen.
    //
    // Read: any authenticated user; role-based access is enforced at the
    // Firestore layer when reading the corresponding reading-log doc.
    // Create/update: <2MB, audio/* content type. Role authorization
    // piggybacks on the parent's Firestore log update (same pattern as
    // community book covers).
    //
    // The platformConfig/comprehensionRecording kill switch is enforced
    // app-side via PlatformConfigService.isComprehensionRecordingEnabled().
    // Storage-rules cross-service Firestore calls were also enforcing it
    // here, but those silently failed under lumi-ninc-au (no comprehension
    // audio ever uploaded after the AU migration) — every upload returned
    // firebase_storage/unauthorized. App-side enforcement is the source of
    // truth; the storage rule trusts auth + size + contentType.
    match /schools/{schoolId}/comprehension_audio/{fileName} {
      // NOT client-readable (2.2). A child's voice is PII at rest; the old
      // `read: if request.auth != null` let ANY authed user fetch ANY child's
      // recording given the path. Playback now goes through the
      // `getComprehensionAudioUrl` callable, which authorizes the caller against
      // the log's school and returns a short-lived signed URL (signed URLs
      // bypass these rules). GATED: deploy only once the app build that fetches
      // via the callable is adopted — older installs still read directly.
      allow read: if false;

      // Create and retry-overwrite use the same canonical owner check. Deletes
      // have request.resource == null and therefore remain Admin-SDK only.
      allow write: if request.resource != null
                   && ownsAudioLog(schoolId, fileName)
                   && comprehensionRecordingEnabled()
                   && request.resource.size < 2 * 1024 * 1024
                   && request.resource.contentType == 'audio/mp4';
    }

    // Default deny for all other paths.
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
