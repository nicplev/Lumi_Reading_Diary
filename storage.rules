rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Community book covers: any authenticated user can read.
    // Teachers and admins can upload (create-only, no overwrite).
    // Nobody can delete from client SDK — only Admin SDK from backend.
    match /community_books/covers/{fileName} {
      allow read: if request.auth != null;

      // Allow creation of JPEG files under 2MB.
      // Role-based authorization is enforced at the Firestore layer
      // (the community_books document write must also succeed).
      allow create: if request.auth != null
                    && request.resource.size < 2 * 1024 * 1024
                    && request.resource.contentType.matches('image/jpeg');

      // Allow cover overwrites (e.g. teacher uploads a better photo).
      // Same constraints as create: authenticated, <2MB, JPEG only.
      allow update: if request.auth != null
                    && request.resource.size < 2 * 1024 * 1024
                    && request.resource.contentType.matches('image/jpeg');

      // No delete from client — only Admin SDK.
      allow delete: if false;
    }

    // Comprehension voice recordings: short m4a clips recorded by children
    // at the end of the parent's reading-log wizard, played back by
    // teachers on the student detail screen.
    //
    // Read: any authenticated user; role-based access is enforced at the
    // Firestore layer when reading the corresponding reading-log doc.
    // Create/update: <2MB, audio/* content type. Role authorization
    // piggybacks on the parent's Firestore log update (same pattern as
    // community book covers).
    match /schools/{schoolId}/comprehension_audio/{fileName} {
      allow read: if request.auth != null;

      // The platformConfig/comprehensionRecording doc is the super-admin
      // kill switch: while it exists with enabled == false, uploads are
      // denied even from stale clients that still show the recording step.
      // Missing doc = feature enabled.
      allow create, update: if request.auth != null
                           && request.resource.size < 2 * 1024 * 1024
                           && request.resource.contentType.matches('audio/.*')
                           && (!firestore.exists(/databases/(default)/documents/platformConfig/comprehensionRecording)
                               || firestore.get(/databases/(default)/documents/platformConfig/comprehensionRecording).data.enabled == true);

      // No client deletes — Admin SDK only. The scheduled cleanup
      // function `cleanupComprehensionAudio` (functions/src/comprehension_retention.ts)
      // is the sole writer driven by /platformConfig/comprehensionRetention.
      allow delete: if false;
    }

    // Default deny for all other paths.
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
