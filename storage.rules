rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Shared conditions for a community book cover write. Deliberately does
    // NOT reference `resource` — see the create/update split below.
    function validCoverUpload() {
      return request.resource != null
          && request.auth != null
          && !isDemoAccount()
          // .get() rather than direct access: a client that omits the key
          // should evaluate to false, not raise a rules error.
          && request.resource.metadata.get('schoolId', '') != ''
          && request.resource.metadata.get('uploaderUid', '') == request.auth.uid
          && request.resource.size < 2 * 1024 * 1024
          && request.resource.contentType == 'image/jpeg';
    }

    function isDemoAccount() {
      return request.auth != null
          && request.auth.token.get('demoAccount', false) == true;
    }

    // NOTE: there are deliberately NO firestore.get() helpers in this file.
    // Storage rules cannot read Firestore in this project — the compiler
    // reports "Invalid function name: firestore.get" and every guarded write
    // fails closed with [firebase_storage/unauthorized]. Removed in PR #107
    // (2026-06-19), silently reintroduced by PR #390 (2026-07-15) — which
    // broke comprehension uploads and book covers for five days — and removed
    // again in PR #475. scripts/check-storage-rules.sh now fails the build if
    // it comes back. Enforce Firestore-dependent conditions in a callable,
    // never here.

    // NOTE: deliberately does NOT call firestore.get(). Cross-service
    // Firestore reads from Storage rules do not work in this project — they
    // fail closed and every upload returns [firebase_storage/unauthorized].
    // This was diagnosed and removed once already (PR #107, 2026-06-19) and
    // silently reintroduced by PR #390 (2026-07-15), which broke comprehension
    // uploads AND community book covers for five days. Do not re-add it
    // without first proving a real-device upload still succeeds.
    //
    // Security is unaffected: this is the UNTRUSTED holding area. Reads are
    // denied outright, and confirmComprehensionAudioUpload re-validates
    // everything with Admin credentials before anything is promoted —
    // parent ownership, teacher-proxy rejection, the platform kill switch,
    // school authority, ftyp signature, size, duration and rate limits —
    // then publishes a separate server-produced canonical object. Residue
    // here expires via the pending-cleanup cron.
    function ownsAudioLog(schoolId, fileName) {
      let logId = request.resource.metadata.logId;
      return request.auth != null &&
          request.resource.metadata.schoolId == schoolId &&
          request.resource.metadata.ownerUid == request.auth.uid &&
          logId is string &&
          fileName == logId + '.m4a';
    }

    // Community book covers: any authenticated user can read.
    // Teachers and admins can upload (create-only, no overwrite).
    // Nobody can delete from client SDK — only Admin SDK from backend.
    match /community_books/covers/{fileName} {
      allow read: if request.auth != null;

      // Only a verified teacher/admin may create a cover. Client overwrites are
      // denied; replacing a shared catalog asset must go through an audited
      // backend path rather than last-writer-wins Storage access.
      // Staff-only was enforced via isStaffAtSchool(), which used the broken
      // cross-service lookup and blocked ALL cover uploads from 2026-07-15.
      // Any authenticated non-demo user may now CREATE a cover (accounts are
      // invite-only), but an existing cover may only be replaced by the
      // person who uploaded it — so a contributor can fix their own blurry
      // photo without anyone being able to overwrite someone else's work on
      // a catalog shared by every school.
      //
      // Legacy covers uploaded before custom metadata existed carry no
      // uploaderUid, so they match nobody and are effectively immutable from
      // the client. That is the intended fail-closed outcome; replacing one
      // needs a backend path with Admin credentials.
      // Split create/update deliberately rather than using `write` with a
      // `resource == null` test: the create path then never references
      // `resource` at all, so it is provable in the Rules test harness (which
      // cannot model an absent existing object and errors on any reference to
      // it). The pre-2026-07-15 rule was shaped this way too.
      allow create: if validCoverUpload();

      // Overwrites are restricted to the original contributor, so someone can
      // fix their own blurry photo without anyone being able to replace
      // another school's work in a catalog shared by everyone. Legacy covers
      // predate custom metadata, carry no uploaderUid, match nobody and are
      // therefore immutable from the client by design — replacing one needs a
      // backend path with Admin credentials.
      allow update: if validCoverUpload()
                    && resource.metadata != null
                    && resource.metadata.get('uploaderUid', '')
                       == request.auth.uid;
    }

    // Client holding area for untrusted comprehension recordings. The parent
    // may create/retry only the pending object bound to their own reading log.
    // The backend fully decodes/transcodes it, writes the separate canonical
    // playback object with Admin credentials, then deletes this pending copy.
    match /comprehension_audio_uploads/{schoolId}/{fileName} {
      allow read: if false;
      // The kill switch and school authority are enforced app-side before the
      // upload is attempted, and again server-side in the confirm callable
      // (the actual boundary). They are NOT checked here — see ownsAudioLog.
      allow write: if request.resource != null
                   && !isDemoAccount()
                   && ownsAudioLog(schoolId, fileName)
                   && request.resource.size < 2 * 1024 * 1024
                   && request.resource.contentType == 'audio/mp4';
    }

    // Trusted, server-produced playback objects. No client may create,
    // overwrite, read or delete these bytes. Teacher playback is exclusively
    // through the class-scoped signed-URL callable.
    match /schools/{schoolId}/comprehension_audio/{fileName} {
      allow read: if false;
      allow write: if false;
    }

    // Default deny for all other paths.
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
